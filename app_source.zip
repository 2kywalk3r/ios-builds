<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
<title>Chicky Dash 🐤</title>
<style>
*{margin:0;padding:0;box-sizing:border-box;}
html,body{width:100%;height:100%;background:#000;display:flex;justify-content:center;align-items:center;overflow:hidden;touch-action:none;user-select:none;}
canvas{display:block;border-radius:18px;}
</style>
</head>
<body>
<canvas id="c"></canvas>
<script>
// ═══════════════════════════════════════════════════════════════════
//  CHICKY DASH v6
// ═══════════════════════════════════════════════════════════════════

// ── Canvas ──────────────────────────────────────────────────────────
const canvas=document.getElementById('c');
const ctx=canvas.getContext('2d');
const BW=400,BH=680;
let W,H,S;
function resize(){S=Math.min(window.innerWidth/BW,window.innerHeight/BH);W=BW*S;H=BH*S;canvas.width=W;canvas.height=H;}
resize();window.addEventListener('resize',resize);

// ── Audio engine ────────────────────────────────────────────────────
let AC=null,musicNodes=null,musicPlaying=false;
function getAC(){if(!AC)try{AC=new(window.AudioContext||window.webkitAudioContext)();}catch(e){}return AC;}
function tone(freq,type,dur,vol=.15,f2=null,delay=0){
  const ac=getAC();if(!ac)return;
  try{
    const o=ac.createOscillator(),g=ac.createGain();
    o.connect(g);g.connect(ac.destination);
    o.type=type;
    const t=ac.currentTime+delay;
    o.frequency.setValueAtTime(freq,t);
    if(f2)o.frequency.exponentialRampToValueAtTime(f2,t+dur);
    g.gain.setValueAtTime(.001,t);
    g.gain.linearRampToValueAtTime(vol,t+.01);
    g.gain.exponentialRampToValueAtTime(.001,t+dur);
    o.start(t);o.stop(t+dur+.05);
  }catch(e){}
}
// SFX
const sfx={
  flap:()=>tone(520,'sine',.09,.1,640),
  coin:()=>{tone(880,'sine',.08,.12);tone(1200,'sine',.1,.1,null,.06);},
  death:()=>{tone(180,'sawtooth',.4,.2,55);tone(90,'square',.5,.1,null,.1);},
  levelup:()=>{[660,770,880,1046].forEach((f,i)=>tone(f,'sine',.12,.14,null,i*.08));},
  powerup:()=>{[440,660,880].forEach((f,i)=>tone(f,'sine',.1,.12,null,i*.07));},
  shield:()=>tone(280,'square',.3,.08,280),
  buy:()=>{tone(660,'sine',.12,.15);tone(990,'sine',.18,.12,null,.1);},
  mission:()=>{[523,659,784,1046].forEach((f,i)=>tone(f,'sine',.14,.13,null,i*.09));},
};

// Generative music
function startMusic(){
  const ac=getAC();if(!ac||musicPlaying)return;
  musicPlaying=true;
  const master=ac.createGain();master.gain.value=.18;master.connect(ac.destination);

  // Bass drone
  const bass=ac.createOscillator(),bassG=ac.createGain();
  bass.type='sine';bass.frequency.value=55;bassG.gain.value=.6;
  bass.connect(bassG);bassG.connect(master);bass.start();

  // Pad (slow LFO wobble)
  const pad=ac.createOscillator(),padG=ac.createGain(),lfo=ac.createOscillator(),lfoG=ac.createGain();
  pad.type='triangle';pad.frequency.value=110;padG.gain.value=.35;
  lfo.frequency.value=.18;lfoG.gain.value=8;
  lfo.connect(lfoG);lfoG.connect(pad.frequency);
  pad.connect(padG);padG.connect(master);
  lfo.start();pad.start();

  // Rhythmic hi-hat
  let beatT=ac.currentTime;
  const BEAT=.22;
  function schedBeat(){
    while(beatT<ac.currentTime+1.0){
      const n=ac.createOscillator(),ng=ac.createGain();
      n.type='square';n.frequency.value=3200+Math.random()*400;
      ng.gain.setValueAtTime(.08,beatT);ng.gain.exponentialRampToValueAtTime(.001,beatT+.04);
      n.connect(ng);ng.connect(master);n.start(beatT);n.stop(beatT+.05);
      beatT+=BEAT;
    }
    setTimeout(schedBeat,400);
  }
  schedBeat();

  // Melody arp (pentatonic)
  const PENTA=[220,247,277,330,370,440,494,554,659,740];
  let melIdx=0,melT=ac.currentTime+.5;
  function schedMel(){
    while(melT<ac.currentTime+1.2){
      const f=PENTA[melIdx%PENTA.length];
      const m=ac.createOscillator(),mg=ac.createGain();
      m.type='triangle';m.frequency.value=f;
      mg.gain.setValueAtTime(.001,melT);mg.gain.linearRampToValueAtTime(.12,melT+.02);
      mg.gain.exponentialRampToValueAtTime(.001,melT+.18);
      m.connect(mg);mg.connect(master);m.start(melT);m.stop(melT+.2);
      melT+=.32;melIdx++;
    }
    setTimeout(schedMel,500);
  }
  schedMel();

  musicNodes={master,bass,pad,lfo};
}
function stopMusic(){
  if(!musicNodes||!musicPlaying)return;
  musicPlaying=false;
  try{
    musicNodes.master.gain.linearRampToValueAtTime(.001,(getAC().currentTime||0)+.5);
    setTimeout(()=>{try{musicNodes.bass.stop();musicNodes.pad.stop();musicNodes.lfo.stop();}catch(e){}},600);
  }catch(e){}
  musicNodes=null;
}
function setMusicTempo(score){
  // Raise melody pitch with level
  if(!musicNodes)return;
  try{
    const lv=Math.min(score/50,1);
    musicNodes.pad.frequency.value=110+lv*55;
  }catch(e){}
}

// ── Haptics ──────────────────────────────────────────────────────────
const hap=p=>{try{navigator.vibrate&&navigator.vibrate(p);}catch(e){}};

// ── Storage ──────────────────────────────────────────────────────────
function lsGet(k,d){try{const v=localStorage.getItem(k);return v===null?d:JSON.parse(v);}catch(e){return d;}}
function lsSet(k,v){try{localStorage.setItem(k,JSON.stringify(v));}catch(e){}}

// ── Constants ────────────────────────────────────────────────────────
const GRAV=.44,FLAP_V=-8.6,TERM_V=13;
const CX=88,CR=19,COIN_R=10,PUP_R=13;
const PIPE_INT=122,DEAD_LOCKOUT=950;

// Smooth difficulty curve (no hard jumps)
function getLevelInfo(sc){
  const t=Math.min(sc/50,1);           // 0..1 over first 50 points
  const spd=2.6+t*2.6;                 // 2.6 → 5.2 smoothly
  const gap=Math.max(125,195-t*70);    // 195 → 125 smoothly
  const lvNum=sc<5?1:sc<10?2:sc<15?3:sc<20?4:sc<28?5:sc<38?6:sc<50?7:8;
  const label=lvNum>=8?'MAX':String(lvNum);
  return{spd,gap,label,lvNum};
}

// Themes
const THEMES=[
  {sky0:'#06061c',sky1:'#0f0420',rt:[0,0,0]},
  {sky0:'#06061c',sky1:'#0f0420',rt:[0,0,0]},
  {sky0:'#1a0508',sky1:'#2a0808',rt:[38,0,0]},
  {sky0:'#1a0508',sky1:'#2a0808',rt:[38,0,0]},
  {sky0:'#050f06',sky1:'#0a1a08',rt:[0,28,0]},
  {sky0:'#050f06',sky1:'#0a1a08',rt:[0,28,0]},
  {sky0:'#000008',sky1:'#07000f',rt:[18,0,38]},
  {sky0:'#000008',sky1:'#07000f',rt:[18,0,38]},
];
function getTheme(sc){const i=getLevelInfo(sc).lvNum-1;return THEMES[Math.min(i,THEMES.length-1)];}

// Skins
const SKINS=[
  {id:'default',name:'Pollito',   price:0,  emoji:'🐤'},
  {id:'astro',  name:'Astronauta',price:30, emoji:'🧑‍🚀'},
  {id:'ninja',  name:'Ninja',     price:50, emoji:'🥷'},
  {id:'cool',   name:'Cool',      price:80, emoji:'😎'},
  {id:'devil',  name:'Diablo',    price:120,emoji:'😈'},
];

// Missions — store only id+done, resolve check at runtime
const MISSION_DEFS=[
  {id:'coins5',   desc:'Recoge 5 monedas',   check:s=>s.coins>=5,   reward:15, goal:s=>5,  prog:s=>Math.min(s.coins,5)},
  {id:'coins12',  desc:'Recoge 12 monedas',  check:s=>s.coins>=12,  reward:25, goal:s=>12, prog:s=>Math.min(s.coins,12)},
  {id:'score8',   desc:'Llega a 8 puntos',   check:s=>s.score>=8,   reward:15, goal:s=>8,  prog:s=>Math.min(s.score,8)},
  {id:'score20',  desc:'Llega a 20 puntos',  check:s=>s.score>=20,  reward:30, goal:s=>20, prog:s=>Math.min(s.score,20)},
  {id:'level3',   desc:'Alcanza nivel 3',    check:s=>+getLevelInfo(s.score).lvNum>=3,reward:20,goal:s=>3,prog:s=>Math.min(getLevelInfo(s.score).lvNum,3)},
  {id:'combo3',   desc:'Combo ×3',           check:s=>s.maxCombo>=3,reward:20, goal:s=>3,  prog:s=>Math.min(s.maxCombo,3)},
  {id:'survive30',desc:'Sobrevive 30 seg',   check:s=>s.seconds>=30,reward:25, goal:s=>30, prog:s=>Math.min(Math.floor(s.seconds),30)},
  {id:'nopowerup',desc:'10 pipes sin morir', check:s=>s.pipesPassed>=10,reward:20,goal:s=>10,prog:s=>Math.min(s.pipesPassed,10)},
];

// ── Game state ────────────────────────────────────────────────────────
let phase='idle';
let score=0,coins=0,combo=1,maxComboGame=0;
let totalCoins=lsGet('cd_coins',0);
let best=lsGet('cd_best',0);
let ownedSkins=lsGet('cd_skins',['default']);
let activeSkin=lsGet('cd_skin','default');
let cy,cvy,frame=0,shakeF=0,deadAt=0,newRecord=false;
let pipes=[],sparks=[],nebulas=[],stars=[];
let levelBanner=0,levelBannerText='',prevLvNum=null;
let missionBanner=0,missionBannerText='';
let coinAnim=0,idleAnim=0,goAnim=0;
let activePU=null;
let seconds=0,pipesPassed=0;
// Screen record animation
let recordAnim=0,recordTarget=0,recordDisplay=0;

// Mission state — persisted by id only
let missions=[];

// Transitions
let fadeAlpha=0,fadeDir=0; // for screen transitions

// Ghost replay
let ghostFrames=[],ghostPlay=[];
let bestRun=lsGet('cd_ghost',[]);

// Leaderboard
let leaderboard=lsGet('cd_lb',[]);

// PU constants
const PU_TYPES=['shield','magnet','slowmo'];
const PU_COL={shield:'#00EFFF',magnet:'#CC44FF',slowmo:'#FFE033'};
const PU_ICO={shield:'🛡',magnet:'🧲',slowmo:'⏱'};
const PU_DUR={shield:3000,magnet:4500,slowmo:3500};

// ── Missions ─────────────────────────────────────────────────────────
function todayKey(){const d=new Date();return`${d.getFullYear()}-${d.getMonth()}-${d.getDate()}`;}
function initMissions(){
  const today=todayKey();
  const saved=lsGet('cd_mis2',null);
  // saved format: {date, ids:[{id,done}]}
  if(saved&&saved.date===today){
    missions=saved.ids.map(({id,done})=>{
      const def=MISSION_DEFS.find(m=>m.id===id);
      return def?{...def,done}:null;
    }).filter(Boolean);
  } else {
    const pool=[...MISSION_DEFS];const chosen=[];
    while(chosen.length<3&&pool.length){
      const i=Math.floor(Math.random()*pool.length);
      chosen.push({...pool[i],done:false});pool.splice(i,1);
    }
    missions=chosen;
    saveMissions();
  }
}
function saveMissions(){lsSet('cd_mis2',{date:todayKey(),ids:missions.map(m=>({id:m.id,done:m.done}))});}
function checkMissions(gs){
  let changed=false;
  for(const m of missions){
    if(!m.done&&m.check(gs)){
      m.done=true;changed=true;
      totalCoins+=m.reward;lsSet('cd_coins',totalCoins);
      missionBanner=130;missionBannerText=`✅ ${m.desc}  +${m.reward}🪙`;
      sfx.mission();hap([20,10,20]);
    }
  }
  if(changed)saveMissions();
}

// ── Init ──────────────────────────────────────────────────────────────
function init(){
  cy=BH/2;cvy=0;frame=0;shakeF=0;
  score=0;coins=0;combo=1;maxComboGame=0;newRecord=false;
  pipes=[];sparks=[];
  levelBanner=0;prevLvNum=null;activePU=null;
  seconds=0;pipesPassed=0;
  recordDisplay=best;recordTarget=best;recordAnim=0;
  ghostFrames=[];
  if(!stars.length){makeStars();makeNebulas();}
}
function makeStars(){stars=Array.from({length:90},()=>({x:Math.random()*BW,y:Math.random()*BH,r:Math.random()*1.4+.3,spd:Math.random()*.5+.1,a:Math.random()*.7+.3}));}
function makeNebulas(){nebulas=Array.from({length:6},()=>({x:Math.random()*BW,y:Math.random()*BH,rx:60+Math.random()*80,ry:30+Math.random()*50,a:Math.random()*.05+.02,spd:Math.random()*.08+.03,hue:Math.random()*360}));}

// ── Input ─────────────────────────────────────────────────────────────
function onTap(){
  getAC();
  if(phase==='idle'){
    startMusic();phase='play';cvy=FLAP_V;sfx.flap();return;
  }
  if(phase==='dead'){
    if(Date.now()-deadAt<DEAD_LOCKOUT)return;
    init();phase='play';cvy=FLAP_V;sfx.flap();return;
  }
  if(phase==='shop')return;
  if(phase==='play'){cvy=FLAP_V;sfx.flap();hap(12);puff(CX,cy,'#FFD700',4);}
}
canvas.addEventListener('pointerdown',e=>{
  e.preventDefault();
  const rect=canvas.getBoundingClientRect();
  const tx=(e.clientX-rect.left)/S,ty=(e.clientY-rect.top)/S;
  if(phase==='idle'){
    if(ty>BH*.85&&Math.abs(tx-BW/2)<60){phase='shop';return;}
  }
  if(phase==='shop'){handleShopTap(tx,ty);return;}
  onTap();
});
document.addEventListener('keydown',e=>{
  if(e.code==='Space'||e.code==='ArrowUp'){e.preventDefault();onTap();}
  if(e.code==='Escape'&&phase==='shop'){phase='idle';}
});

// ── Sparks ────────────────────────────────────────────────────────────
function puff(bx,by,color,n=5){
  for(let i=0;i<n;i++){const a=Math.random()*Math.PI*2,sp=1+Math.random()*3;sparks.push({x:bx,y:by,vx:Math.cos(a)*sp,vy:Math.sin(a)*sp,life:1,decay:.055+Math.random()*.04,r:2+Math.random()*3,color});}
}
function puffDeath(bx,by){
  const c=['#FFE033','#FF8C00','#FF4444','#fff','#FFB347'];
  for(let i=0;i<32;i++){const a=(i/32)*Math.PI*2,sp=2+Math.random()*6;sparks.push({x:bx,y:by,vx:Math.cos(a)*sp,vy:Math.sin(a)*sp-2,life:1,decay:.022+Math.random()*.026,r:3+Math.random()*6,color:c[i%5]});}
}
function puffCoin(bx,by){for(let i=0;i<10;i++){const a=Math.random()*Math.PI*2,sp=1.5+Math.random()*3;sparks.push({x:bx,y:by,vx:Math.cos(a)*sp,vy:Math.sin(a)*sp,life:1,decay:.06+Math.random()*.04,r:2+Math.random()*3,color:'#FFD700'});}}
function puffLevel(){for(let i=0;i<40;i++){const a=Math.random()*Math.PI*2,sp=2+Math.random()*5;sparks.push({x:BW/2+Math.random()*BW-.5*BW,y:BH/2+Math.random()*BH-.5*BH,vx:Math.cos(a)*sp,vy:Math.sin(a)*sp-2,life:1,decay:.018+Math.random()*.022,r:3+Math.random()*5,color:['#FFE033','#FF88FF','#88FFFF','#FF8800','#fff'][i%5]});}}

// ── Rocks ─────────────────────────────────────────────────────────────
function makeVerts(seed,r,n=8){
  const v=[];
  for(let i=0;i<n;i++){const a=(i/n)*Math.PI*2;const rr=r*(.7+(Math.sin(seed*i*2.3+1.1)*.5+.5)*.42);v.push(Math.cos(a)*rr,Math.sin(a)*rr);}
  return v;
}
function buildClusters(gapY,gap){
  const topEnd=gapY-gap/2,botStart=gapY+gap/2,rocks=[],seed=Math.random()*100;
  function cluster(isTop){
    const totalH=isTop?topEnd:BH-botStart;
    if(totalH<14)return;
    const ar=Math.min(24+Math.random()*10,totalH*.55);
    const verts=makeVerts(seed+(isTop?0:50),ar);
    // Cache gradient params on rock itself
    const shade=118+Math.random()*30;
    rocks.push({x:0,y:isTop?topEnd-ar*.6:botStart+ar*.6,r:ar,verts,shade,cachedGrad:null});
    const rows=Math.ceil(totalH/38);
    for(let i=0;i<rows;i++){
      const r=11+Math.random()*13;
      const safe=Math.max(0,totalH-ar*1.3-r*2);
      const y=isTop?Math.random()*safe:botStart+ar*1.3+Math.random()*safe;
      const sh=92+Math.random()*44;
      rocks.push({x:(Math.random()-.5)*26,y,r,verts:makeVerts(seed+(isTop?0:50)+i+2,r),shade:sh,cachedGrad:null});
    }
  }
  cluster(true);cluster(false);
  return rocks;
}
function spawnPipe(){
  const lv=getLevelInfo(score);
  const gap=lv.gap;
  const minY=BH*.17+gap/2,maxY=BH*.83-gap/2;
  const gapY=minY+Math.random()*(maxY-minY);
  const hasPU=Math.random()<.18;
  const pcoins=[];
  if(hasPU){
    const type=PU_TYPES[Math.floor(Math.random()*PU_TYPES.length)];
    const margin=gap*.25;
    pcoins.push({type:'pu',puType:type,ox:0,oy:gapY+(Math.random()-.5)*(gap-margin*2),collected:false});
  } else {
    const cnt=Math.random()<.6?1:2;
    for(let i=0;i<cnt;i++){
      const margin=gap*.28;
      const oy=gapY+(Math.random()-.5)*(gap-margin*2);
      const ox=cnt===2?(i===0?-18:18):0;
      pcoins.push({type:'coin',ox,oy,collected:false});
    }
  }
  pipes.push({bx:BW+35,gapY,gap,rocks:buildClusters(gapY,gap),coins:pcoins,passed:false,hasCoin:!hasPU});
}

// ── Collision ─────────────────────────────────────────────────────────
function collides(){
  const shielded=activePU&&activePU.type==='shield'&&Date.now()<activePU.endTime;
  if(shielded)return false;
  const r=CR*.74;
  if(cy-r<0||cy+r>BH)return true;
  for(const p of pipes){
    if(p.bx<CX-55||p.bx>CX+55)continue;
    for(const rock of p.rocks){
      const dx=CX-(p.bx+rock.x),dy=cy-rock.y;
      if(dx*dx+dy*dy<(r+rock.r*.72)*(r+rock.r*.72))return true;
    }
  }
  return false;
}
function checkPickups(){
  const mag=activePU&&activePU.type==='magnet'&&Date.now()<activePU.endTime;
  for(const p of pipes){
    if(p.bx<CX-90||p.bx>CX+90)continue;
    for(const c of p.coins){
      if(c.collected)continue;
      const dx=CX-(p.bx+c.ox),dy=cy-c.oy;
      const dist2=dx*dx+dy*dy;
      const pickR=c.type==='coin'?(mag?65:CR+COIN_R):(CR+PUP_R);
      if(dist2<pickR*pickR){
        c.collected=true;
        if(c.type==='coin'){
          const earned=combo;
          coins+=earned;totalCoins+=earned;lsSet('cd_coins',totalCoins);
          if(combo<3)combo++;
          if(combo>maxComboGame)maxComboGame=combo;
          puffCoin(p.bx+c.ox,c.oy);sfx.coin();hap(20);
        } else {
          activePU={type:c.puType,endTime:Date.now()+PU_DUR[c.puType]};
          puff(p.bx+c.ox,c.oy,PU_COL[c.puType],14);sfx.powerup();hap([15,10,15]);
        }
      }
    }
    // Miss coin → reset combo (only if pipe has coins and all uncollected coins passed chick)
    if(p.hasCoin&&p.bx<CX-50&&p.coins.some(c=>c.type==='coin'&&!c.collected)){
      combo=1;
    }
  }
}

// ── Draw helpers ──────────────────────────────────────────────────────
function rrect(x,y,w,h,r){
  ctx.beginPath();
  ctx.moveTo(x+r,y);ctx.lineTo(x+w-r,y);ctx.quadraticCurveTo(x+w,y,x+w,y+r);
  ctx.lineTo(x+w,y+h-r);ctx.quadraticCurveTo(x+w,y+h,x+w-r,y+h);
  ctx.lineTo(x+r,y+h);ctx.quadraticCurveTo(x,y+h,x,y+h-r);
  ctx.lineTo(x,y+r);ctx.quadraticCurveTo(x,y,x+r,y);
  ctx.closePath();
}

// Draw rock with cached gradient (performance fix)
function drawRock(rock,bx,tint){
  const px=(bx+rock.x)*S,py=rock.y*S,rs=rock.r*S;
  const v=rock.verts,s=rock.shade;
  ctx.save();ctx.translate(px,py);
  ctx.beginPath();
  for(let i=0;i<v.length;i+=2)i===0?ctx.moveTo(v[i]*S,v[i+1]*S):ctx.lineTo(v[i]*S,v[i+1]*S);
  ctx.closePath();
  const tr=tint||[0,0,0];
  // Create gradient fresh (canvas gradients are position-absolute, must recreate on move)
  const g=ctx.createRadialGradient(-rs*.25,-rs*.25,0,0,0,rs*1.1);
  g.addColorStop(0,`rgb(${Math.min(255,s+38+tr[0])},${Math.min(255,s+28+tr[1])},${Math.min(255,s+13+tr[2])})`);
  g.addColorStop(.6,`rgb(${Math.min(255,s+tr[0])},${Math.max(0,s-10+tr[1])},${Math.max(0,s-18+tr[2])})`);
  g.addColorStop(1,`rgb(${Math.max(0,s-34+tr[0])},${Math.max(0,s-40+tr[1])},${Math.max(0,s-46+tr[2])})`);
  ctx.fillStyle=g;ctx.fill();
  ctx.strokeStyle='rgba(0,0,0,.28)';ctx.lineWidth=.8;ctx.stroke();
  ctx.beginPath();ctx.arc(rs*.2,-rs*.2,rs*.17,0,Math.PI*2);ctx.fillStyle='rgba(0,0,0,.17)';ctx.fill();
  ctx.restore();
}

function drawCoin(cx2,cy2,anim){
  const px=cx2*S,py=cy2*S,r=COIN_R*S,scX=Math.abs(Math.cos(anim));
  ctx.save();ctx.translate(px,py);ctx.scale(scX,1);
  const g=ctx.createRadialGradient(-r*.3,-r*.3,0,0,0,r*1.1);
  g.addColorStop(0,'#FFF176');g.addColorStop(.5,'#FFD700');g.addColorStop(1,'#E65C00');
  ctx.beginPath();ctx.arc(0,0,r,0,Math.PI*2);ctx.fillStyle=g;ctx.fill();
  ctx.strokeStyle='rgba(255,180,0,.5)';ctx.lineWidth=1;ctx.stroke();
  ctx.fillStyle='rgba(120,60,0,.6)';ctx.font=`bold ${r*1.1}px system-ui`;
  ctx.textAlign='center';ctx.textBaseline='middle';ctx.fillText('$',0,0);
  ctx.restore();
}

function drawPowerup(cx2,cy2,puType,anim){
  const px=cx2*S,py=cy2*S,r=PUP_R*S,col=PU_COL[puType];
  const pulse=1+Math.sin(anim*2)*.12;
  ctx.save();ctx.translate(px,py);ctx.scale(pulse,pulse);
  ctx.beginPath();ctx.arc(0,0,r,0,Math.PI*2);
  ctx.fillStyle=col+'33';ctx.fill();
  ctx.strokeStyle=col;ctx.lineWidth=2*S;ctx.stroke();
  ctx.font=`${r*1.3}px system-ui`;ctx.textAlign='center';ctx.textBaseline='middle';
  ctx.fillText(PU_ICO[puType],0,1*S);
  ctx.restore();
}

// Magnet attraction lines
function drawMagnetLines(){
  if(!activePU||activePU.type!=='magnet'||Date.now()>=activePU.endTime)return;
  const alpha=(activePU.endTime-Date.now())/PU_DUR.magnet;
  for(const p of pipes){
    for(const c of p.coins){
      if(c.collected||c.type!=='coin')continue;
      const cx2=p.bx+c.ox,cy2=c.oy;
      const dx=CX-cx2,dy=cy-cy2,dist=Math.sqrt(dx*dx+dy*dy);
      if(dist>90)continue;
      const lineA=alpha*(1-dist/90)*.7;
      ctx.save();
      ctx.strokeStyle=`rgba(200,68,255,${lineA})`;
      ctx.lineWidth=1.5*S;ctx.setLineDash([4*S,4*S]);
      ctx.beginPath();ctx.moveTo(cx2*S,cy2*S);ctx.lineTo(CX*S,cy*S);ctx.stroke();
      ctx.setLineDash([]);
      ctx.restore();
    }
  }
}

// ── Chick ─────────────────────────────────────────────────────────────
function drawChick(skin,ox,oy,vel,ghostMode){
  skin=skin||activeSkin;
  const r=CR*S;
  const vc=vel!==undefined?vel:cvy;
  const rawA=vc*.038;
  const angle=Math.max(-.42,Math.min(.50,rawA));
  const isScared=vc>6,isTerror=vc>10;
  const shielded=activePU&&activePU.type==='shield'&&Date.now()<activePU.endTime;
  const magnetOn=activePU&&activePU.type==='magnet'&&Date.now()<activePU.endTime;
  const slowOn=activePU&&activePU.type==='slowmo'&&Date.now()<activePU.endTime;

  ctx.save();
  if(ghostMode){ctx.globalAlpha=.3;}
  ctx.translate((ox||CX)*S,(oy||cy)*S);ctx.rotate(angle);

  // Power-up aura rings
  if(shielded&&!ghostMode){
    ctx.shadowColor='rgba(0,240,255,.8)';ctx.shadowBlur=22*S;
    ctx.strokeStyle=`rgba(0,240,255,${.4+Math.sin(Date.now()*.009)*.3})`;
    ctx.lineWidth=3*S;ctx.beginPath();ctx.arc(0,0,r*1.38,0,Math.PI*2);ctx.stroke();
    ctx.shadowBlur=0;
  }
  if(magnetOn&&!ghostMode){
    ctx.strokeStyle=`rgba(200,68,255,${.3+Math.sin(Date.now()*.007)*.2})`;
    ctx.lineWidth=2*S;ctx.setLineDash([3*S,3*S]);
    ctx.beginPath();ctx.arc(0,0,r*1.5,0,Math.PI*2);ctx.stroke();
    ctx.setLineDash([]);
  }
  if(slowOn&&!ghostMode){
    ctx.strokeStyle=`rgba(255,224,51,${.3+Math.sin(Date.now()*.006)*.2})`;
    ctx.lineWidth=2*S;ctx.beginPath();ctx.arc(0,0,r*1.28,0,Math.PI*2);ctx.stroke();
  }

  ctx.shadowColor='rgba(255,215,50,.5)';ctx.shadowBlur=13*S;
  const bg=ctx.createRadialGradient(-r*.27,-r*.28,r*.08,0,0,r);
  bg.addColorStop(0,'#FFF580');bg.addColorStop(.5,'#FFD020');bg.addColorStop(1,'#E89000');
  ctx.beginPath();ctx.ellipse(0,0,r,r*.93,0,0,Math.PI*2);ctx.fillStyle=bg;ctx.fill();
  ctx.shadowBlur=0;

  const tailShake=isScared?(Math.random()-.5)*.3:0;
  ctx.beginPath();
  ctx.moveTo(-r*.62,-r*.08+tailShake);ctx.quadraticCurveTo(-r*1.18,-r*.42,-r*.98,r*.22);
  ctx.quadraticCurveTo(-r*.84,r*.08,-r*.58,r*.18);
  ctx.fillStyle='#FFB300';ctx.fill();
  ctx.beginPath();ctx.ellipse(-r*.54,r*.14,r*.37,r*.24,-.28,0,Math.PI*2);ctx.fillStyle='#F0BA00';ctx.fill();

  // Skin extras
  if(skin==='astro'){
    ctx.strokeStyle='rgba(150,220,255,.45)';ctx.lineWidth=4*S;
    ctx.beginPath();ctx.ellipse(0,-r*.05,r*.9,r*.86,0,0,Math.PI*2);ctx.stroke();
    ctx.fillStyle='rgba(100,200,255,.1)';ctx.fill();
  }
  if(skin==='devil'){
    ctx.fillStyle='#CC0000';
    ctx.beginPath();ctx.moveTo(-r*.18,-r*.88);ctx.lineTo(-r*.04,-r*.52);ctx.lineTo(-r*.32,-r*.52);ctx.fill();
    ctx.beginPath();ctx.moveTo(r*.18,-r*.88);ctx.lineTo(r*.32,-r*.52);ctx.lineTo(r*.04,-r*.52);ctx.fill();
  }

  ctx.beginPath();ctx.arc(r*.4,-r*.3,r*.32,0,Math.PI*2);ctx.fillStyle='#fff';ctx.fill();
  if(isTerror){
    ctx.strokeStyle='#333';ctx.lineWidth=2*S;
    ctx.beginPath();ctx.moveTo(r*.3,-r*.38);ctx.lineTo(r*.5,-r*.22);ctx.stroke();
    ctx.beginPath();ctx.moveTo(r*.5,-r*.38);ctx.lineTo(r*.3,-r*.22);ctx.stroke();
  } else {
    const pd=isScared?r*.08:Math.max(-r*.09,Math.min(r*.09,vc*S*.01));
    const pr=isScared?r*.14:r*.18;
    ctx.beginPath();ctx.arc(r*.47,-r*.3+pd,pr,0,Math.PI*2);ctx.fillStyle='#18102e';ctx.fill();
    ctx.beginPath();ctx.arc(r*.53,-r*.38,r*.07,0,Math.PI*2);ctx.fillStyle='#fff';ctx.fill();
  }

  if(skin==='cool'||skin==='ninja'){
    const gc=ctx.createLinearGradient(-r*.55,-r*.28,r*.7,-r*.28);
    gc.addColorStop(0,skin==='ninja'?'#CC0000':'#222');gc.addColorStop(1,skin==='ninja'?'#880000':'#444');
    rrect(-r*.58*S ? -r*.58:-r*.58,-r*.44,r*1.22,r*.28,r*.08);
    ctx.fillStyle=gc;ctx.fill();
    if(skin==='cool'){
      ctx.fillStyle='rgba(0,200,255,.3)';
      ctx.beginPath();ctx.arc(r*.28,-r*.3,r*.2,0,Math.PI*2);ctx.fill();
      ctx.beginPath();ctx.arc(-r*.08,-r*.3,r*.2,0,Math.PI*2);ctx.fill();
    }
  }

  ctx.beginPath();
  if(isTerror){ctx.arc(r*.78,r*.1,r*.18,0,Math.PI);}
  else{ctx.moveTo(r*.78,-r*.05);ctx.lineTo(r*1.22,r*.04);ctx.lineTo(r*.78,r*.2);ctx.closePath();}
  ctx.fillStyle='#FF8800';ctx.fill();

  ctx.globalAlpha=ghostMode?.3:.26;
  ctx.beginPath();ctx.ellipse(r*.18,r*.16,r*.24,r*.14,.14,0,Math.PI*2);ctx.fillStyle='#FF8080';ctx.fill();
  ctx.globalAlpha=1;
  ctx.restore();
}

// ── Background ─────────────────────────────────────────────────────────
function drawBg(){
  const th=getTheme(score);
  const bg=ctx.createLinearGradient(0,0,0,H);
  bg.addColorStop(0,th.sky0);bg.addColorStop(1,th.sky1);
  ctx.fillStyle=bg;ctx.fillRect(0,0,W,H);
  const mv=phase==='play';
  for(const n of nebulas){if(mv)n.x-=n.spd;if(n.x<-120)n.x=BW+120;const g=ctx.createRadialGradient(n.x*S,n.y*S,0,n.x*S,n.y*S,n.rx*S);g.addColorStop(0,`hsla(${n.hue},80%,60%,${n.a})`);g.addColorStop(1,'transparent');ctx.fillStyle=g;ctx.fillRect(0,0,W,H);}
  for(const s of stars){if(mv){s.x-=s.spd;if(s.x<0){s.x=BW;s.y=Math.random()*BH;}}ctx.globalAlpha=s.a;ctx.fillStyle='#fff';ctx.beginPath();ctx.arc(s.x*S,s.y*S,s.r*S,0,Math.PI*2);ctx.fill();}
  ctx.globalAlpha=1;
}

// ── HUD ────────────────────────────────────────────────────────────────
function drawHUD(){
  const lv=getLevelInfo(score);

  // Score — animate on new record
  ctx.textAlign='center';ctx.shadowColor='rgba(0,0,0,.5)';ctx.shadowBlur=7*S;
  ctx.font=`900 ${50*S}px system-ui`;
  ctx.fillStyle='rgba(255,255,255,.13)';ctx.fillText(score,W/2+2*S,72*S+2*S);
  if(newRecord){
    // Gold pulsing score
    const pulse=1+Math.sin(Date.now()*.008)*.06;
    ctx.save();ctx.translate(W/2,72*S);ctx.scale(pulse,pulse);ctx.translate(-W/2,-72*S);
    ctx.fillStyle='#FFD700';ctx.fillText(score,W/2,72*S);
    ctx.restore();
  } else {
    ctx.fillStyle='#fff';ctx.fillText(score,W/2,72*S);
  }
  ctx.shadowBlur=0;

  // Coins + combo
  ctx.textAlign='right';ctx.font=`bold ${15*S}px system-ui`;
  const comboStr=combo>1?` ×${combo}`:'';
  ctx.fillStyle='rgba(255,215,0,.85)';ctx.fillText(`🪙 ${coins}${comboStr}`,W-12*S,34*S);

  // Level badge
  ctx.textAlign='left';ctx.font=`bold ${12*S}px system-ui`;
  ctx.fillStyle='rgba(255,255,255,.3)';ctx.fillText('LVL',13*S,25*S);
  ctx.font=`900 ${20*S}px system-ui`;ctx.fillStyle='rgba(255,220,50,.8)';ctx.fillText(lv.label,13*S,44*S);

  // Active PU bar
  if(activePU&&Date.now()<activePU.endTime){
    const rem=(activePU.endTime-Date.now())/PU_DUR[activePU.type];
    const col=PU_COL[activePU.type];
    const barW=80*S,barH=8*S,bx=(BW/2-40)*S,by=90*S;
    ctx.fillStyle='rgba(255,255,255,.08)';rrect(bx,by,barW,barH,4*S);ctx.fill();
    ctx.fillStyle=col+'99';rrect(bx,by,barW*rem,barH,4*S);ctx.fill();
    ctx.font=`${11*S}px system-ui`;ctx.textAlign='center';ctx.fillStyle=col;
    ctx.fillText(PU_ICO[activePU.type]+' '+activePU.type.toUpperCase(),W/2,by+barH+12*S);
  }

  // Level banner
  if(levelBanner>0){
    levelBanner--;
    const a=Math.min(1,levelBanner/20)*Math.min(1,levelBanner/8);
    ctx.globalAlpha=Math.max(0,a);ctx.textAlign='center';
    ctx.font=`900 ${30*S}px system-ui`;ctx.fillStyle='#FFE033';
    ctx.shadowColor='rgba(255,180,0,.7)';ctx.shadowBlur=20*S;
    ctx.fillText(levelBannerText,W/2,BH*.36*S);ctx.shadowBlur=0;ctx.globalAlpha=1;
  }

  // Mission banner
  if(missionBanner>0){
    missionBanner--;
    const a=Math.min(1,missionBanner/15)*Math.min(1,missionBanner/10);
    ctx.globalAlpha=Math.max(0,a);ctx.textAlign='center';
    ctx.font=`bold ${13*S}px system-ui`;ctx.fillStyle='#88FF88';
    ctx.shadowColor='rgba(0,255,0,.5)';ctx.shadowBlur=14*S;
    ctx.fillText(missionBannerText,W/2,BH*.28*S);ctx.shadowBlur=0;ctx.globalAlpha=1;
  }
}

// ── IDLE ───────────────────────────────────────────────────────────────
function drawIdle(){
  idleAnim+=.03;
  ctx.fillStyle='rgba(6,6,28,.5)';ctx.fillRect(0,0,W,H);

  const oldCy=cy,oldCvy=cvy;
  cy=BH*.41+Math.sin(idleAnim)*8;cvy=Math.cos(idleAnim)*2;
  drawChick(activeSkin);cy=oldCy;cvy=oldCvy;

  ctx.textAlign='center';
  ctx.font=`900 ${50*S}px system-ui`;ctx.fillStyle='#FFE033';
  ctx.shadowColor='rgba(255,180,0,.5)';ctx.shadowBlur=26*S;
  ctx.fillText('Chicky Dash',W/2,BH*.19*S);ctx.shadowBlur=0;

  ctx.font=`${11*S}px system-ui`;ctx.fillStyle='rgba(255,255,255,.36)';
  ctx.fillText('ESQUIVA ASTEROIDES · RECOGE MONEDAS',W/2,BH*.255*S);

  // Missions with progress bars
  const my=BH*.3*S;
  const gs={coins,score,seconds,maxCombo:maxComboGame,pipesPassed};
  missions.forEach((m,i)=>{
    const by=my+i*32*S;
    const bw=290*S,bh=25*S,bx=(W-bw)/2;
    ctx.fillStyle=m.done?'rgba(100,255,100,.1)':'rgba(255,255,255,.06)';
    rrect(bx,by,bw,bh,6*S);ctx.fill();

    // Progress bar
    if(!m.done){
      const prog=m.prog(gs),goal=m.goal(gs);
      const pct=Math.min(1,prog/goal);
      if(pct>0){
        ctx.fillStyle='rgba(255,215,0,.25)';rrect(bx,by,bw*pct,bh,6*S);ctx.fill();
      }
    }

    ctx.font=`${11*S}px system-ui`;ctx.fillStyle=m.done?'rgba(120,255,120,.75)':'rgba(255,255,255,.55)';
    ctx.textAlign='left';ctx.fillText((m.done?'✅ ':'○ ')+m.desc,bx+10*S,by+17*S);
    ctx.textAlign='right';ctx.fillStyle='rgba(255,215,0,.6)';
    ctx.fillText(`+${m.reward}🪙`,bx+bw-8*S,by+17*S);
  });

  const blink=.5+.5*Math.sin(Date.now()/380);
  ctx.globalAlpha=blink;ctx.font=`bold ${17*S}px system-ui`;ctx.fillStyle='#FFD700';
  ctx.textAlign='center';ctx.fillText('TAP para comenzar',W/2,BH*.75*S);ctx.globalAlpha=1;

  if(best>0||totalCoins>0){
    ctx.font=`${13*S}px system-ui`;ctx.fillStyle='rgba(255,215,0,.5)';ctx.textAlign='center';
    ctx.fillText(`🏆 ${best}   🪙 ${totalCoins}`,W/2,BH*.81*S);
  }

  // Shop button
  const sbx=W/2-44*S,sby=BH*.86*S;
  ctx.fillStyle='rgba(180,120,255,.2)';rrect(sbx,sby,88*S,28*S,8*S);ctx.fill();
  ctx.strokeStyle='rgba(180,120,255,.45)';ctx.lineWidth=1.5;ctx.stroke();
  ctx.font=`bold ${13*S}px system-ui`;ctx.fillStyle='rgba(220,180,255,.9)';ctx.textAlign='center';
  ctx.fillText('🏪 TIENDA',W/2,sby+19*S);
}

// ── SHOP ───────────────────────────────────────────────────────────────
function handleShopTap(tx,ty){
  if(ty<55){phase='idle';return;}
  SKINS.forEach((sk,i)=>{
    const by=130+i*90;
    if(ty>by-5&&ty<by+80){
      const owned=ownedSkins.includes(sk.id);
      if(owned){activeSkin=sk.id;lsSet('cd_skin',activeSkin);sfx.coin();}
      else if(totalCoins>=sk.price){
        totalCoins-=sk.price;lsSet('cd_coins',totalCoins);
        ownedSkins=[...ownedSkins,sk.id];lsSet('cd_skins',ownedSkins);
        activeSkin=sk.id;lsSet('cd_skin',activeSkin);
        sfx.buy();hap([20,10,30]);puff(BW/2,BH/2,'#FFD700',20);
      } else {hap(60);}
    }
  });
}

let shopIdleAnim=0;
function drawShop(){
  shopIdleAnim+=.04;
  ctx.fillStyle='rgba(5,3,20,.94)';ctx.fillRect(0,0,W,H);
  ctx.textAlign='center';
  ctx.font=`900 ${28*S}px system-ui`;ctx.fillStyle='#CC88FF';
  ctx.shadowColor='rgba(180,100,255,.5)';ctx.shadowBlur=18*S;
  ctx.fillText('🏪 TIENDA',W/2,36*S);ctx.shadowBlur=0;

  ctx.font=`${13*S}px system-ui`;ctx.fillStyle='rgba(255,215,0,.7)';
  ctx.fillText(`🪙 ${totalCoins} monedas`,W/2,58*S);
  ctx.font=`${10*S}px system-ui`;ctx.fillStyle='rgba(255,255,255,.25)';
  ctx.fillText('TAP ARRIBA PARA VOLVER',W/2,74*S);

  SKINS.forEach((sk,i)=>{
    const by=130+i*90,bx=BW/2-160,bw=320,bh=78;
    const owned=ownedSkins.includes(sk.id),active=activeSkin===sk.id,canBuy=totalCoins>=sk.price;

    ctx.fillStyle=active?'rgba(255,220,50,.14)':owned?'rgba(255,255,255,.07)':canBuy?'rgba(255,255,255,.04)':'rgba(255,255,255,.02)';
    rrect(bx*S,by*S,bw*S,bh*S,12*S);ctx.fill();
    ctx.strokeStyle=active?'rgba(255,220,50,.5)':owned?'rgba(255,255,255,.14)':'rgba(255,255,255,.07)';
    ctx.lineWidth=active?2:1;ctx.stroke();

    // Mini animated chick preview
    const previewX=bx+30,previewY=by+40+Math.sin(shopIdleAnim+i)*.6;
    const savedCy=cy,savedCvy=cvy;
    cy=previewY;cvy=Math.cos(shopIdleAnim+i)*.5;
    const savedCR=CR;
    // Draw at half size using save/restore
    ctx.save();
    const scFactor=.55;
    ctx.translate(previewX*S,previewY*S);
    ctx.scale(scFactor,scFactor);
    ctx.translate(-previewX*S,-previewY*S);
    // Temporarily shift CX to previewX by drawing manually
    const savedActiveSkin=activeSkin;activeSkin=sk.id;
    const tempCX=CX;
    // We need to draw at previewX, not CX — use a local translate trick
    const offX=(previewX-CX)*S/scFactor;
    ctx.translate(offX,0);
    drawChick(sk.id);
    ctx.restore();
    activeSkin=savedActiveSkin;cy=savedCy;cvy=savedCvy;

    ctx.font=`bold ${15*S}px system-ui`;ctx.fillStyle='#fff';ctx.textAlign='left';
    ctx.fillText(sk.name,(bx+56)*S,(by+28)*S);
    ctx.font=`${11*S}px system-ui`;

    if(active){ctx.fillStyle='rgba(255,220,50,.7)';ctx.fillText('✓ ACTIVO',(bx+56)*S,(by+48)*S);}
    else if(owned){ctx.fillStyle='rgba(180,255,180,.55)';ctx.fillText('Toca para usar',(bx+56)*S,(by+48)*S);}
    else{ctx.fillStyle=canBuy?'rgba(255,215,0,.9)':'rgba(255,100,100,.55)';ctx.font=`bold ${14*S}px system-ui`;ctx.fillText(`🪙 ${sk.price}`,(bx+56)*S,(by+48)*S);}
  });
}

// ── DEAD ───────────────────────────────────────────────────────────────
async function shareScore(){
  try{
    const blob=await new Promise(r=>canvas.toBlob(r,'image/png'));
    const file=new File([blob],'chicky-dash.png',{type:'image/png'});
    if(navigator.canShare&&navigator.canShare({files:[file]})){
      await navigator.share({title:'Chicky Dash',text:`¡Hice ${score} puntos en Chicky Dash! 🐤`,files:[file]});
    } else {
      await navigator.share({title:'Chicky Dash',text:`¡Hice ${score} puntos en Chicky Dash! 🐤`});
    }
  }catch(e){
    // fallback: copy to clipboard
    try{await navigator.clipboard.writeText(`¡Hice ${score} puntos en Chicky Dash! 🐤`);}catch(e2){}
  }
}

let shareTapped=false;
function drawDead(){
  const elapsed=Date.now()-deadAt;
  goAnim=Math.min(1,elapsed/280);
  const slideY=BH/2+(1-goAnim)*(1-goAnim)*BH*.38;

  const pw=BW*.85*S,ph=BH*.52*S;
  const px=(W-pw)/2,py=slideY*S-ph/2;

  ctx.fillStyle=`rgba(8,5,24,${.9*goAnim})`;
  rrect(px,py,pw,ph,20*S);ctx.fill();
  ctx.strokeStyle=`rgba(255,80,80,${.3*goAnim})`;ctx.lineWidth=1.5*S;ctx.stroke();

  ctx.globalAlpha=goAnim;ctx.textAlign='center';const mx=W/2;

  ctx.font=`900 ${34*S}px system-ui`;ctx.fillStyle='#FF4444';
  ctx.shadowColor='rgba(255,50,50,.4)';ctx.shadowBlur=16*S;
  ctx.fillText('💥  Game Over',mx,py+48*S);ctx.shadowBlur=0;

  ctx.strokeStyle='rgba(255,255,255,.07)';ctx.lineWidth=1;
  ctx.beginPath();ctx.moveTo(px+20*S,py+62*S);ctx.lineTo(px+pw-20*S,py+62*S);ctx.stroke();

  const bw=pw*.37,bh=60*S,b1x=mx-pw*.24,b2x=mx+pw*.24,by=py+ph*.36;
  [[b1x,'PUNTAJE',score,'#fff'],[b2x,'RÉCORD',best,'#FFD700']].forEach(([bx2,lbl,val,col])=>{
    ctx.fillStyle='rgba(255,255,255,.05)';rrect(bx2-bw/2,by-bh/2,bw,bh,10*S);ctx.fill();
    ctx.font=`${10*S}px system-ui`;ctx.fillStyle='rgba(255,255,255,.34)';ctx.fillText(lbl,bx2,by-10*S);
    ctx.font=`900 ${30*S}px system-ui`;ctx.fillStyle=col;ctx.fillText(val,bx2,by+18*S);
  });

  ctx.font=`${12*S}px system-ui`;ctx.fillStyle='rgba(255,215,0,.65)';
  ctx.fillText(`🪙 +${coins}  combo×${maxComboGame}  ${Math.floor(seconds)}s`,mx,by+bh/2+14*S);
  if(newRecord&&score>0){ctx.font=`bold ${12*S}px system-ui`;ctx.fillStyle='#FFD700';ctx.shadowColor='rgba(255,220,0,.4)';ctx.shadowBlur=10*S;ctx.fillText('✨ ¡NUEVO RÉCORD!',mx,by+bh/2+30*S);ctx.shadowBlur=0;}

  // Mini leaderboard
  const lb=leaderboard.slice(0,4);
  if(lb.length){
    ctx.font=`${9*S}px system-ui`;ctx.fillStyle='rgba(255,255,255,.22)';
    ctx.fillText('─── Últimas partidas ───',mx,by+bh/2+46*S);
    lb.forEach((r,i)=>{
      ctx.fillStyle=i===0?'rgba(255,215,0,.45)':'rgba(255,255,255,.28)';
      ctx.fillText(`${i+1}. ${r.score}pts  🪙${r.coins}  ${r.secs}s`,mx,by+bh/2+58*S+i*13*S);
    });
  }

  // Share button
  const sbx=mx-40*S,sby=py+ph-52*S;
  ctx.fillStyle='rgba(100,150,255,.2)';rrect(sbx,sby,80*S,22*S,8*S);ctx.fill();
  ctx.strokeStyle='rgba(100,150,255,.4)';ctx.lineWidth=1;ctx.stroke();
  ctx.font=`${11*S}px system-ui`;ctx.fillStyle='rgba(180,200,255,.8)';
  ctx.fillText('📤 Compartir',mx,sby+15*S);

  // Lockout bar
  const lockP=Math.min(1,elapsed/DEAD_LOCKOUT);
  const barW=pw*.68,barH=5*S,barX=mx-barW/2,barY=py+ph-26*S;
  ctx.fillStyle='rgba(255,255,255,.08)';rrect(barX,barY,barW,barH,3*S);ctx.fill();
  ctx.fillStyle=lockP>=1?'#FFD700':'rgba(255,180,0,.4)';rrect(barX,barY,barW*lockP,barH,3*S);ctx.fill();

  if(lockP>=1){
    const bl=.45+.45*Math.sin(Date.now()/340);
    ctx.globalAlpha=bl*goAnim;ctx.font=`${13*S}px system-ui`;ctx.fillStyle='rgba(255,255,255,.5)';
    ctx.fillText('TAP para reintentar',mx,py+ph-10*S);
  } else {
    ctx.font=`${11*S}px system-ui`;ctx.fillStyle='rgba(255,255,255,.22)';ctx.fillText('Espera...',mx,py+ph-10*S);
  }
  ctx.globalAlpha=1;

  // Share tap detection
  canvas.onclick=null;
  canvas.addEventListener('pointerdown',function shareListen(e){
    const rect=canvas.getBoundingClientRect();
    const tx=(e.clientX-rect.left)/S,ty=(e.clientY-rect.top)/S;
    const sy2=slideY-ph/S/2;
    if(ty>sy2+ph/S-56&&ty<sy2+ph/S-30&&Math.abs(tx-BW/2)<44){
      shareScore();canvas.removeEventListener('pointerdown',shareListen);
    }
  },{once:true});
}

// ── Ghost replay ───────────────────────────────────────────────────────
function drawGhost(){
  if(!bestRun||!bestRun.length)return;
  const f=frame%bestRun.length;
  const g=bestRun[f];
  if(!g)return;
  drawChick(lsGet('cd_ghostSkin','default'),CX,g,0,true);
}

// ── MAIN LOOP ──────────────────────────────────────────────────────────
function tick(){
  requestAnimationFrame(tick);
  coinAnim+=.07;

  if(phase==='play'){
    frame++;
    if(frame%PIPE_INT===1)spawnPipe();

    const lv=getLevelInfo(score);
    if(prevLvNum!==null&&prevLvNum!==lv.lvNum){
      levelBanner=90;levelBannerText=`⬆ NIVEL ${lv.label}`;
      sfx.levelup();hap([10,10,10]);puffLevel();setMusicTempo(score);
    }
    prevLvNum=lv.lvNum;

    const slowmo=activePU&&activePU.type==='slowmo'&&Date.now()<activePU.endTime;
    const spd=lv.spd*(slowmo?.5:1);

    for(const p of pipes)p.bx-=spd;
    pipes=pipes.filter(p=>p.bx>-80);
    if(pipes.length>12)pipes=pipes.slice(pipes.length-12);

    for(const p of pipes){
      if(!p.passed&&p.bx<CX){
        p.passed=true;score++;pipesPassed++;
        if(score>best){best=score;newRecord=true;lsSet('cd_best',best);}
      }
    }

    checkPickups();
    cvy=Math.min(cvy+GRAV,TERM_V);cy+=cvy;
    seconds=frame/60;

    // Record ghost frame
    ghostFrames.push(cy);
    if(ghostFrames.length>3000)ghostFrames=ghostFrames.slice(ghostFrames.length-3000);

    checkMissions({score,coins,seconds,maxCombo:maxComboGame,pipesPassed});

    if(collides()){
      phase='dead';deadAt=Date.now();shakeF=14;
      puffDeath(CX,cy);sfx.death();hap(80);stopMusic();
      // Save best ghost run
      if(score>=best){lsSet('cd_ghost',ghostFrames.slice(0,Math.min(ghostFrames.length,1800)));lsSet('cd_ghostSkin',activeSkin);}
      leaderboard.unshift({score,coins,secs:Math.floor(seconds),combo:maxComboGame});
      if(leaderboard.length>10)leaderboard.length=10;
      lsSet('cd_lb',leaderboard);
    }
  }

  for(const s of sparks){s.x+=s.vx;s.y+=s.vy;s.vy+=.12;s.life-=s.decay;}
  sparks=sparks.filter(s=>s.life>0);
  if(sparks.length>150)sparks=sparks.slice(sparks.length-150);

  // ── DRAW ────────────────────────────────────────────────────────────
  drawBg();

  let sx=0,sy=0;
  if(shakeF>0){shakeF--;const m=shakeF*.45;sx=(Math.random()-.5)*m*S*4;sy=(Math.random()-.5)*m*S*2.5;}

  ctx.save();ctx.translate(sx,sy);

  if(phase!=='idle'&&phase!=='shop'){
    const th=getTheme(score);
    for(const p of pipes){
      for(const r of p.rocks)drawRock(r,p.bx,th.rt);
      for(const c of p.coins){
        if(!c.collected){
          if(c.type==='coin')drawCoin(p.bx+c.ox,c.oy,coinAnim);
          else drawPowerup(p.bx+c.ox,c.oy,c.puType,coinAnim);
        }
      }
    }
    drawMagnetLines();
    if(phase==='play'&&bestRun.length)drawGhost();
  }

  if(phase==='play')drawChick();

  for(const s of sparks){
    ctx.globalAlpha=Math.max(0,s.life);ctx.fillStyle=s.color;
    ctx.beginPath();ctx.arc(s.x*S,s.y*S,s.r*S*Math.max(.1,s.life),0,Math.PI*2);ctx.fill();
  }
  ctx.globalAlpha=1;
  ctx.restore();

  if(phase==='idle')drawIdle();
  if(phase==='play')drawHUD();
  if(phase==='dead'){drawHUD();drawDead();}
  if(phase==='shop')drawShop();
}

// ── BOOT ──────────────────────────────────────────────────────────────
bestRun=lsGet('cd_ghost',[]);
initMissions();
init();
tick();
</script>
</body>
</html>
