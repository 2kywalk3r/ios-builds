// ══════════════════════════════════════════════════════
// STATE & REACTIVE ARCHITECTURE
// ══════════════════════════════════════════════════════
const AVATAR_COLORS=['#6b8cff','#ff6b6b','#c8ff00','#ff9f43','#a29bfe','#fd79a8','#00b894','#fdcb6e'];
let currentLang=localStorage.getItem('ig_lang')||'es';
if(currentLang==='en'){currentLang='en-US';localStorage.setItem('ig_lang','en-US');}
if(!LANGS[currentLang])currentLang='es';

let blacklist=new Set(JSON.parse(localStorage.getItem('ig_blacklist')||'[]'));
let appHistory=JSON.parse(localStorage.getItem('ig_history')||'[]');
let savedRatio=JSON.parse(localStorage.getItem('ig_ratio')||'null');
let openPopover=null;
let currentTab='notFollowing';
let currentList=[];
let sortAZ=false;
let analysisMode='all';

// Non-destructive state using ES6 getters for live filtering
let state={
  rawFollowers: [],
  rawFollowing: [],
  get followers() {
    return this.rawFollowers.filter(u => !blacklist.has(u));
  },
  get following() {
    return this.rawFollowing.filter(u => !blacklist.has(u));
  },
  get notFollowing() {
    const followersSet = new Set(this.followers);
    const followingSet = new Set(this.following);
    if(analysisMode==='all'){
      return this.following.filter(u => !followersSet.has(u));
    } else {
      return this.followers.filter(u => !followingSet.has(u));
    }
  },
  get mutual() {
    const followersSet = new Set(this.followers);
    const followingSet = new Set(this.following);
    if(analysisMode==='all'){
      return this.following.filter(u => followersSet.has(u));
    } else {
      return this.followers.filter(u => followingSet.has(u));
    }
  }
};

function T(k){return LANGS[currentLang]?.t[k]||LANGS.es.t[k]||k;}

// ══════════════════════════════════════════════════════
// LANGUAGE
// ══════════════════════════════════════════════════════
function toggleLangDropdown(e){e.stopPropagation();document.getElementById('langDropdown').classList.toggle('open');}

function setLang(lang,e){
  if(e)e.stopPropagation();
  currentLang=lang;
  localStorage.setItem('ig_lang',lang);
  document.getElementById('langDropdown').classList.remove('open');
  applyLang();
}

function applyLang(){
  const l=LANGS[currentLang];
  document.getElementById('langFlag').textContent=l.flag;
  document.getElementById('langCode').textContent=l.code;
  document.documentElement.lang=currentLang;
  document.body.classList.toggle('rtl',l.dir==='rtl');
  document.querySelectorAll('.lang-option').forEach(o=>o.classList.toggle('active',o.dataset.lang===currentLang));

  // Static upload page
  document.getElementById('heroTitle').innerHTML=T('heroTitle');
  document.getElementById('heroSub').textContent=T('heroSub');
  document.getElementById('privacyStrong').textContent=T('privacyStrong');
  document.getElementById('privacySub').textContent=T('privacySub');
  document.getElementById('stepsLabel').textContent=T('stepsLabel');
  document.getElementById('step1').innerHTML=T('step1');
  document.getElementById('step2').innerHTML=T('step2');
  document.getElementById('step3').innerHTML=T('step3');
  document.getElementById('step4').innerHTML=T('step4');
  document.getElementById('modeLabel').textContent=T('modeLabel');
  document.getElementById('modeAllTitle').textContent=T('modeAllTitle');
  document.getElementById('modeAllDesc').textContent=T('modeAllDesc');
  document.getElementById('modePeriodTitle').textContent=T('modePeriodTitle');
  document.getElementById('modePeriodDesc').textContent=T('modePeriodDesc');
  document.getElementById('uploadTitle').textContent=T('uploadTitle');
  document.getElementById('uploadDesc').innerHTML=T('uploadDesc');
  document.getElementById('uploadBtn').textContent=T('uploadBtn');
  document.getElementById('analyzingText').textContent=T('analyzing');
  // Stats labels
  document.getElementById('labelNotFollow').textContent=T('statNotFollow');
  document.getElementById('labelFollowers').textContent=T('statFollowers');
  document.getElementById('labelFollowing').textContent=T('statFollowing');
  document.getElementById('labelMutual').textContent=T('statMutual');
  // Ratio
  document.getElementById('ratioLabel').textContent=T('ratioLabel');
  document.getElementById('ratioLabelLocked').textContent=T('ratioLabel');
  document.getElementById('ratioLockedMsg').textContent=T('ratioLockedMsg');
  // History
  document.getElementById('historyLabel').textContent=T('historyLabel');
  // Search
  document.getElementById('searchBar').placeholder=T('searchPlaceholder');
  // Tabs
  document.getElementById('tabNotFollowing').textContent=T('tabNotFollowing');
  document.getElementById('tabMutual').textContent=T('tabMutual');
  document.getElementById('tabFollowers').textContent=T('tabFollowers');
  document.getElementById('tabFollowing').textContent=T('tabFollowing');
  document.getElementById('tabBlacklist').textContent=T('tabBlacklist');
  renderBlacklistBadge();
  // Buttons
  document.getElementById('exportTxtBtn').textContent=T('exportTxt');
  document.getElementById('exportCsvBtn').textContent=T('exportCsv');
  document.getElementById('resetBtn').textContent=T('resetBtn');
  document.getElementById('clearHistBtn').textContent=T('clearHistBtn');
  // Modal
  document.getElementById('blacklistModalTitle').textContent=T('blacklistModalTitle');
  document.getElementById('blacklistModalDesc').textContent=T('blacklistModalDesc');
  // Precision note
  document.getElementById('precisionNote').innerHTML=T('precisionNote');

  // Re-render dynamic content if results are visible
  if(document.getElementById('results').style.display!=='none'){
    const tabKey='tab'+currentTab.charAt(0).toUpperCase()+currentTab.slice(1);
    document.getElementById('listTitle').textContent=T(tabKey).replace(/^[^\s]+\s/,'');
    renderHistory();
    renderList(currentList);
  }
}

document.addEventListener('click',()=>{
  document.getElementById('langDropdown').classList.remove('open');
  closeAllPopups();
});

// ══════════════════════════════════════════════════════
// THEME
// ══════════════════════════════════════════════════════
let theme=localStorage.getItem('ig_theme')||'dark';
applyTheme(theme);
function applyTheme(t){theme=t;document.documentElement.setAttribute('data-theme',t);document.getElementById('themeBtn').textContent=t==='dark'?'☀️':'🌙';localStorage.setItem('ig_theme',t);}
document.getElementById('themeBtn').addEventListener('click',()=>applyTheme(theme==='dark'?'light':'dark'));

// ══════════════════════════════════════════════════════
// MODE
// ══════════════════════════════════════════════════════
function selectMode(mode){
  analysisMode=mode;
  document.getElementById('modeAll').classList.toggle('selected',mode==='all');
  document.getElementById('modePeriod').classList.toggle('selected',mode==='period');
}

// ══════════════════════════════════════════════════════
// UPLOAD & READERS
// ══════════════════════════════════════════════════════
document.getElementById('uploadBtn').addEventListener('click',e=>{e.preventDefault();document.getElementById('fileInput').click();});
document.getElementById('fileInput').addEventListener('change',e=>{const f=Array.from(e.target.files);if(f.length)processFiles(f);});
const uploadCard=document.getElementById('uploadCard');
uploadCard.addEventListener('dragover',e=>{e.preventDefault();uploadCard.classList.add('drag-over');});
uploadCard.addEventListener('dragleave',()=>uploadCard.classList.remove('drag-over'));
uploadCard.addEventListener('drop',e=>{e.preventDefault();uploadCard.classList.remove('drag-over');processFiles(Array.from(e.dataTransfer.files));});

function processFiles(files){
  hideError();
  if(!files.length)return showError(T('errNoFile'));
  if(files.length>2)return showError(T('errTooMany'));
  
  for(const f of files){
    if(!f.name.toLowerCase().endsWith('.json')){
      return showError(T('errRead')+f.name+' — '+({es:'debe ser .json',en:'must be .json','en-US':'must be .json','en-GB':'must be .json',pt:'deve ser .json',fr:'doit être .json',de:'muss .json sein',ja:'.jsonが必要',hi:'.json होना चाहिए',ar:'يجب أن يكون .json',id:'harus .json',ru:'должен быть .json'}[currentLang]||'must be .json'));
    }
  }
  showLoading(true);
  let fRaw=null,gRaw=null,done=0;
  files.forEach(file=>{
    const reader=new FileReader();
    reader.onload=ev=>{
      try{
        const json=JSON.parse(ev.target.result);
        const users=getUsers(json);
        if(!Array.isArray(users)||users.length===0){
          if(!Array.isArray(json)&&!json.relationships_following&&!json.relationships_followers&&!Object.values(json||{}).some(v=>Array.isArray(v))){
            showLoading(false);showError(T('errRead')+file.name+' — formato no reconocido');return;
          }
        }
        const n=file.name.toLowerCase();
        if(n.includes('follower'))fRaw=json;
        else if(n.includes('following'))gRaw=json;
        else{if(!fRaw)fRaw=json;else gRaw=json;}
      }catch(e){showLoading(false);showError(T('errRead')+file.name);return;}
      done++;if(done===files.length)buildResults(fRaw,gRaw);
    };reader.readAsText(file);
  });
}

// Highly robust extractor prioritizing pure values over displays
function getUsers(json){
  if(!json)return[];
  let arr=json;
  if(!Array.isArray(json))arr=json.relationships_following || json.relationships_followers || Object.values(json).find(v=>Array.isArray(v))||[];
  return arr.map(i=>{
    const val = i?.string_list_data?.[0]?.value || i?.value || i?.title;
    return typeof val === 'string' ? val.trim() : null;
  }).filter(Boolean);
}

// ══════════════════════════════════════════════════════
// BUILD RESULTS
// ══════════════════════════════════════════════════════
function buildResults(fRaw,gRaw){
  setTimeout(()=>{
    const followers=new Set(getUsers(fRaw));
    const following=new Set(getUsers(gRaw));
    
    // Feed raw state database
    state.rawFollowers=[...followers];
    state.rawFollowing=[...following];
    
    updateStats();updateRatio();
    
    // Save state history (independent of real-time blacklist filtering to avoid math artifacts)
    saveHistory({
      followers:[...followers],
      following:[...following],
      notFollowing: analysisMode==='all'?[...following].filter(u=>!followers.has(u)):[...followers].filter(u=>!following.has(u)),
      mutual: analysisMode==='all'?[...following].filter(u=>followers.has(u)):[...followers].filter(u=>following.has(u))
    });
    
    renderHistory();renderBlacklistBadge();
    showLoading(false);
    document.getElementById('results').style.display='block';
    
    saveSession();
    activateTab('notFollowing');
    showToast(T('toastDone'));
  },500);
}

function updateStats(){
  document.getElementById('statFollowers').textContent=state.followers.length;
  document.getElementById('statFollowing').textContent=state.following.length;
  document.getElementById('statNotFollow').textContent=state.notFollowing.length;
  document.getElementById('statMutual').textContent=state.mutual.length;
}

// ══════════════════════════════════════════════════════
// RATIO
// ══════════════════════════════════════════════════════
function updateRatio(){
  const ratioWrap=document.getElementById('ratioWrap');
  const ratioLocked=document.getElementById('ratioLocked');
  if(analysisMode==='all'){
    const ratio=state.following.length>0?Math.round((state.followers.length/state.following.length)*100):0;
    savedRatio={ratio,followers:state.followers.length,following:state.following.length,date:new Date().toLocaleDateString()};
    localStorage.setItem('ig_ratio',JSON.stringify(savedRatio));
    document.getElementById('ratioText').textContent=ratio+'%';
    setTimeout(()=>{document.getElementById('ratioFill').style.width=Math.min(ratio,100)+'%';},100);
    ratioWrap.style.display='block';ratioLocked.style.display='none';
  }else{
    ratioWrap.style.display='none';ratioLocked.style.display='block';
    if(savedRatio){
      document.getElementById('ratioSaved').textContent=savedRatio.ratio+'%';
      setTimeout(()=>{document.getElementById('ratioFillSaved').style.width=Math.min(savedRatio.ratio,100)+'%';},100);
    }else{document.getElementById('ratioSaved').textContent='—';document.getElementById('ratioFillSaved').style.width='0%';}
  }
}

// ══════════════════════════════════════════════════════
// HISTORY
// ══════════════════════════════════════════════════════
function saveHistory(s){
  const prevSameMode=appHistory.find(h=>h.mode===analysisMode);
  let gained=0,lost=0;
  if(prevSameMode&&analysisMode==='all'){
    const prevSet=new Set(prevSameMode.users.notFollowing||[]);const currSet=new Set(s.notFollowing);
    lost=[...currSet].filter(u=>!prevSet.has(u)).length;gained=[...prevSet].filter(u=>!currSet.has(u)).length;
  }
  const entry={date:new Date().toLocaleDateString(),time:new Date().toLocaleTimeString([],{hour:'2-digit',minute:'2-digit'}),timestamp:Date.now(),mode:analysisMode,notFollowing:s.notFollowing.length,mutual:s.mutual.length,followers:s.followers.length,following:s.following.length,gained,lost,users:{notFollowing:[...s.notFollowing],mutual:[...s.mutual],followers:[...s.followers],following:[...s.following]}};
  appHistory.unshift(entry);
  if(appHistory.length>15)appHistory=appHistory.slice(0,15);
  localStorage.setItem('ig_history',JSON.stringify(appHistory));
}

function renderHistory(){
  if(appHistory.length<1){document.getElementById('historySection').style.display='none';return;}
  document.getElementById('historySection').style.display='block';
  const strip=document.getElementById('historyStrip');
  strip.innerHTML=appHistory.map((h,i)=>{
    const prev=appHistory.find((x,xi)=>xi>i&&x.mode===h.mode);
    const diff=prev?h.notFollowing-prev.notFollowing:null;
    let diffStr,diffCls;
    if(diff===null){diffStr=T('diffFirst');diffCls='neutral';}
    else if(diff>0){diffStr=`-${diff} ${T('diffLost')}`;diffCls='lost';}
    else if(diff<0){diffStr=`+${Math.abs(diff)} ${T('diffGained')}`;diffCls='gained';}
    else{diffStr=T('diffNone');diffCls='neutral';}
    const modeIcon=h.mode==='all'?'🌐':'📅';
    const modeStr=h.mode==='all'?T('modeFullHistory'):T('modePeriodShort');
    return `<div class="history-chip" id="hchip${i}" onclick="togglePopoverEl(${i},event)">
      <span class="hdate">${modeIcon} ${h.date} ${h.time||''}</span>
      <span class="hdiff ${diffCls}">${diffStr}</span>
      <div class="history-popover" id="hpop${i}">
        <h5>📊 ${T('popDetail')} ${h.date} ${h.time||''}</h5>
        <div class="popover-row"><span>${T('popMode')}</span><span>${modeStr}</span></div>
        <div class="popover-row"><span>${T('popNotFollow')}</span><span class="red">${h.notFollowing}</span></div>
        <div class="popover-row"><span>${T('popFollowers')}</span><span class="green">${h.followers}</span></div>
        <div class="popover-row"><span>${T('popFollowing')}</span><span>${h.following}</span></div>
        <div class="popover-row"><span>${T('popMutual')}</span><span>${h.mutual}</span></div>
        ${diff!==null&&diff>0?`<div class="popover-row"><span>${T('popLost')}</span><span class="red">-${diff}</span></div>`:''}
        ${diff!==null&&diff<0?`<div class="popover-row"><span>${T('popGained')}</span><span class="green">+${Math.abs(diff)}</span></div>`:''}
      </div>
    </div>`;
  }).join('');
}

function togglePopoverEl(i,e){
  e.stopPropagation();
  openHistPopup(i,e);
}

function clearHistory(){
  if(!confirm(T('confirmClear')))return;
  appHistory=[];localStorage.removeItem('ig_history');
  document.getElementById('historySection').style.display='none';
  showToast(T('toastHistCleared'));
}

// ══════════════════════════════════════════════════════
// CLOSE ALL POPUPS
// ══════════════════════════════════════════════════════
function closeAllPopups(){
  const rp=document.getElementById('ratioPopup');
  rp.classList.remove('open');
  rp.style.transform='';
  document.getElementById('histPopup').classList.remove('open');
  document.getElementById('popupOverlay').classList.remove('open');
  if(openPopover){openPopover.classList.remove('open');openPopover=null;}
}

// ══════════════════════════════════════════════════════
// RATIO POPUP (100% Internationalized)
// ══════════════════════════════════════════════════════
function openRatioPopup(e){
  e.stopPropagation();
  const isLocked = analysisMode !== 'all';
  const ratio = savedRatio ? savedRatio.ratio : 0;

  document.getElementById('rp_title').textContent = '📊 ' + T('ratioLabel');
  document.getElementById('rp_value').textContent = ratio !== null ? ratio + '%' : '—';
  document.getElementById('rp_value').style.color = ratio===null?'var(--muted)':ratio>=100?'var(--green)':ratio>=50?'var(--accent)':'var(--red)';

  const explain1 = {
    es:'El ratio muestra la relación entre <strong>cuántas personas te siguen</strong> y <strong>cuántas sigues tú</strong>. Si sigues a 100 personas y 150 te siguen a ti, tu ratio es 150%.',
    'en-US':'The ratio shows the relationship between <strong>how many people follow you</strong> and <strong>how many you follow</strong>. If you follow 100 people and 150 follow you, your ratio is 150%.',
    'en-GB':'The ratio shows the relationship between <strong>how many people follow you</strong> and <strong>how many you follow</strong>. If you follow 100 people and 150 follow you, your ratio is 150%.',
    pt:'O ratio mostra a relação entre <strong>quantas pessoas te seguem</strong> e <strong>quantas você segue</strong>. Se você segue 100 pessoas e 150 te seguem, seu ratio é 150%.',
    fr:'Le ratio montre la relation entre <strong>combien de personnes te suivent</strong> et <strong>combien tu suis</strong>. Si tu suis 100 personnes et que 150 te suivent, ton ratio est de 150 %.',
    de:'Das Verhältnis zeigt die Beziehung zwischen <strong>wie vielen Personen dir folgen</strong> und <strong>wie vielen du folgst</strong>. Wenn du 100 Personen folgst und 150 dir folgen, beträgt dein Verhältnis 150 %.',
    ja:'比率は<strong>あなたをフォローしている人数</strong>と<strong>あなたがフォローしている人数</strong>の関係を示します。100人をフォローして150人がフォローバックすれば比率は150%です。',
    hi:'रेशियो यह दिखाता है कि <strong>कितने लोग आपको फॉलो करते हैं</strong> और <strong>आप कितनों को फॉलो करते हैं</strong>। अगर आप 100 को फॉलो करते हैं और 150 आपको, तो रेशियो 150% है।',
    ar:'تُظهر النسبة العلاقة بين <strong>عدد من يتابعونك</strong> و<strong>عدد من تتابعهم</strong>. إذا تابعت 100 شخص وتابعك 150، فنسبتك 150٪.',
    id:'Rasio menunjukkan hubungan antara <strong>berapa banyak orang yang mengikutimu</strong> dan <strong>berapa banyak yang kamu ikuti</strong>. Jika kamu mengikuti 100 orang dan 150 mengikutimu, rasiomu adalah 150%.',
    ru:'Соотношение показывает связь между <strong>тем, сколько людей подписано на тебя</strong>, и <strong>тем, на сколько подписан ты сам</strong>. Если ты подписан на 100 человек, а 150 подписаны на тебя, твоё соотношение — 150%.'
  };
  const explain2 = {
    es:'Un ratio <strong>por encima de 100%</strong> significa que te siguen más personas de las que sigues tú. Por <strong>debajo de 100%</strong> sigues a más gente de la que te sigue a ti.',
    'en-US':'A ratio <strong>above 100%</strong> means more people follow you than you follow. <strong>Below 100%</strong> means you follow more people than follow you.',
    'en-GB':'A ratio <strong>above 100%</strong> means more people follow you than you follow. <strong>Below 100%</strong> means you follow more people than follow you.',
    pt:'Um ratio <strong>acima de 100%</strong> significa que mais pessoas te seguem do que você segue. <strong>Abaixo de 100%</strong> significa que você segue mais do que te seguem.',
    fr:'Un ratio <strong>supérieur à 100 %</strong> signifie que plus de personnes te suivent que tu n\'en suis. <strong>En dessous de 100 %</strong>, tu suis plus de monde que tu n\'en as.',
    de:'Ein Verhältnis <strong>über 100 %</strong> bedeutet, dass dir mehr Leute folgen als du folgst. <strong>Unter 100 %</strong> folgst du mehr Leuten als dir folgen.',
    ja:'<strong>100%以上</strong>はあなたをフォローする人数があなたがフォローする人数より多いことを意味します。<strong>100%未満</strong>はその逆です。',
    hi:'<strong>100% से ऊपर</strong> का मतलब है कि आपको फॉलो करने वाले ज्यादा हैं। <strong>100% से नीचे</strong> मतलब आप ज्यादा फॉलो करते हैं।',
    ar:'نسبة <strong>تزيد عن 100٪</strong> تعني أن من يتابعونك أكثر ممن تتابعهم. <strong>أقل من 100٪</strong> يعني العكس.',
    id:'Rasio <strong>di atas 100%</strong> berarti lebih banyak orang mengikutimu daripada yang kamu ikuti. <strong>Di bawah 100%</strong> berarti sebaliknya.',
    ru:'Соотношение <strong>выше 100%</strong> означает, что на тебя подписано больше людей, чем ты сам. <strong>Ниже 100%</strong> — наоборот.'
  };
  document.getElementById('rp_explain1').innerHTML = explain1[currentLang]||explain1['en-US'];
  document.getElementById('rp_explain2').innerHTML = explain2[currentLang]||explain2['en-US'];
  document.getElementById('rp_formula').textContent = T('ratioFormula');

  const scaleLabels = {
    es:['Bajo','Equilibrado','Alto'], 'en-US':['Low','Balanced','High'], 'en-GB':['Low','Balanced','High'],
    pt:['Baixo','Equilibrado','Alto'], fr:['Bas','Équilibré','Haut'], de:['Niedrig','Ausgeglichen','Hoch'],
    ja:['低い','バランス','高い'], hi:['कम','संतुलित','अधिक'], ar:['منخفض','متوازن','مرتفع'], id:['Rendah','Seimbang','Tinggi'], ru:['Низкий','Сбалансированный','Высокий']
  };
  const sl = scaleLabels[currentLang]||scaleLabels['en-US'];
  document.getElementById('rp_scale').innerHTML=`
    <div class="ratio-scale-item"><div class="rs-val" style="color:var(--red)">< 50%</div><div class="rs-label">${sl[0]}</div></div>
    <div class="ratio-scale-item"><div class="rs-val" style="color:var(--accent)">50–100%</div><div class="rs-label">${sl[1]}</div></div>
    <div class="ratio-scale-item"><div class="rs-val" style="color:var(--green)">> 100%</div><div class="rs-label">${sl[2]}</div></div>
  `;

  document.getElementById('rp_sublabel').textContent = savedRatio ? `${savedRatio.followers} / ${savedRatio.following}` : '';
  setTimeout(()=>{document.getElementById('rp_fill').style.width=Math.min(ratio,150)/1.5+'%';},50);
  document.getElementById('rp_fill').style.background = ratio>=100?'var(--green)':ratio>=50?'var(--accent)':'var(--red)';

  const lockedEl = document.getElementById('rp_locked');
  if(isLocked){
    lockedEl.style.display='block';
    lockedEl.textContent = T('ratioLockedMsg');
  }else{
    lockedEl.style.display='none';
  }

  document.getElementById('ratioPopup').classList.add('open');
  document.getElementById('popupOverlay').classList.add('open');
}

// Swipe gesture algorithm for closing popups
(function initRatioSwipe(){
  const pop=document.getElementById('ratioPopup');
  const grab=document.getElementById('ratioPopupGrab');
  if(!pop||!grab)return;
  let startY=0,curY=0,dragging=false;
  const onStart=(y)=>{startY=y;curY=0;dragging=true;pop.classList.add('dragging');};
  const onMove=(y)=>{
    if(!dragging)return;
    curY=Math.max(0,y-startY);
    pop.style.transform='translateY('+curY+'px)';
  };
  const onEnd=()=>{
    if(!dragging)return;
    dragging=false;
    pop.classList.remove('dragging');
    if(curY>90){
      pop.style.transform='translateY(100%)';
      setTimeout(()=>{pop.style.transform='';closeAllPopups();},220);
    }else{
      pop.style.transform='';
    }
  };
  grab.addEventListener('touchstart',e=>onStart(e.touches[0].clientY),{passive:true});
  grab.addEventListener('touchmove',e=>{onMove(e.touches[0].clientY);},{passive:true});
  grab.addEventListener('touchend',onEnd);
  grab.addEventListener('touchcancel',onEnd);
  grab.addEventListener('mousedown',e=>{onStart(e.clientY);
    const mm=ev=>onMove(ev.clientY);
    const mu=()=>{document.removeEventListener('mousemove',mm);document.removeEventListener('mouseup',mu);onEnd();};
    document.addEventListener('mousemove',mm);document.addEventListener('mouseup',mu);
  });
})();

// ══════════════════════════════════════════════════════
// HISTORY COMPARISON POPUP
// ══════════════════════════════════════════════════════
function openHistPopup(idx, e){
  e.stopPropagation();
  closeAllPopups();
  const h = appHistory[idx];
  if(!h) return;
  const prev = appHistory.find((x,xi)=>xi>idx && x.mode===h.mode);

  const modeStr = h.mode==='all'?T('modeFullHistory'):T('modePeriodShort');
  const modeIcon = h.mode==='all'?'🌐':'📅';
  document.getElementById('hp_title').textContent = `📊 ${h.date} ${h.time||''} · ${modeStr}`;

  const maxVal = Math.max(h.followers, h.following, h.notFollowing, h.mutual, 1);
  const bar = (val, color) => `<div class="hist-compare-bar" style="width:${Math.round(val/maxVal*100)}%;background:${color}"></div>`;

  const labels = {
    followers: T('popFollowers'), following: T('popFollowing'),
    notFollowing: T('popNotFollow'), mutual: T('popMutual')
  };
  const colors = { followers:'var(--green)', following:'var(--accent3)', notFollowing:'var(--red)', mutual:'var(--accent)' };

  let bars = ['followers','following','notFollowing','mutual'].map(k=>`
    <div class="hist-compare-row">
      <div class="hist-compare-label">${labels[k]}</div>
      <div class="hist-compare-bar-wrap">${bar(h[k],colors[k])}</div>
      <div class="hist-compare-val" style="color:${colors[k]}">${h[k]}</div>
    </div>`).join('');

  let deltas = '';
  if(prev){
    const diffNF = h.notFollowing - prev.notFollowing;
    const diffF  = h.followers - prev.followers;
    const diffFg = h.following - prev.following;
    const diffM  = h.mutual - prev.mutual;
    const fmt = (n,reverse=false) => {
      const good = reverse ? n<0 : n>0;
      const cls = n===0?'hist-delta-neu':good?'hist-delta-pos':'hist-delta-neg';
      const sign = n>0?'+':'';
      return `<span class="${cls}">${sign}${n}</span>`;
    };
    const vsLabel = {
      es:'vs análisis anterior','en-US':'vs previous analysis','en-GB':'vs previous analysis',
      pt:'vs análise anterior',fr:'vs analyse précédente',de:'vs vorherige Analyse',
      ja:'前回比',hi:'पिछले विश्लेषण से',ar:'مقارنة بالتحليل السابق',id:'vs analisis sebelumnya',ru:'по сравнению с предыдущим'
    };
    deltas = `
      <div style="background:var(--card2);border-radius:12px;padding:12px 14px;margin-top:16px">
        <div style="font-size:11px;font-weight:700;color:var(--muted);letter-spacing:1.5px;text-transform:uppercase;margin-bottom:10px">${vsLabel[currentLang]||vsLabel['en-US']} (${prev.date})</div>
        <div class="hist-delta-row"><span>${T('popFollowers')}</span>${fmt(diffF)}</div>
        <div class="hist-delta-row"><span>${T('popFollowing')}</span>${fmt(diffFg)}</div>
        <div class="hist-delta-row"><span>${T('popNotFollow')}</span>${fmt(diffNF,true)}</div>
        <div class="hist-delta-row"><span>${T('popMutual')}</span>${fmt(diffM)}</div>
      </div>`;
  }

  document.getElementById('hp_body').innerHTML = bars + deltas;
  setTimeout(()=>{
    document.querySelectorAll('.hist-compare-bar').forEach(b=>{
      const w=b.style.width; b.style.width='0'; setTimeout(()=>{b.style.width=w;b.style.transition='width .7s cubic-bezier(.4,0,.2,1)';},30);
    });
  },10);

  document.getElementById('histPopup').classList.add('open');
  document.getElementById('popupOverlay').classList.add('open');
}

// ══════════════════════════════════════════════════════
// BLACKLIST (Clean non-destructive architecture)
// ══════════════════════════════════════════════════════
function toggleBlacklist(username){
  if(blacklist.has(username)){
    blacklist.delete(username);
    showToast('✅ @'+username+' '+T('toastRemoved'));
  }else{
    blacklist.add(username);
    showToast('🚫 @'+username+' '+T('toastAdded'));
  }
  localStorage.setItem('ig_blacklist',JSON.stringify([...blacklist]));
  renderBlacklistBadge();
  updateStats();
  
  currentList=currentTab==='blacklist'?[...blacklist]:(state[currentTab]||[]);
  document.getElementById('listCount').textContent=currentList.length;
  renderList(currentList);
  
  if(document.getElementById('blacklistModal').classList.contains('open')){
    const c=document.getElementById('blacklistContent');
    if(!blacklist.size){c.innerHTML=`<div class="empty"><span>✅</span><p>${T('blacklistEmpty')}</p></div>`;}
    else{c.innerHTML=[...blacklist].map(u=>`<div class="user-item"><div class="avatar" style="background:${avatarColor(u)}">${u[0].toUpperCase()}</div><div class="user-info"><div class="username">@${u}</div></div><button class="btn-block blocked" onclick="toggleBlacklist('${u}')">${T('blacklistRemove')}</button></div>`).join('');}
  }
}

function renderBlacklistBadge(){
  const tabEl=document.getElementById('tabBlacklist');
  const base=T('tabBlacklist');
  tabEl.textContent = blacklist.size>0 ? `${base} (${blacklist.size})` : base;
}

function openBlacklist(){
  document.getElementById('blacklistModal').classList.add('open');
  const c=document.getElementById('blacklistContent');
  if(!blacklist.size){c.innerHTML=`<div class="empty"><span>✅</span><p>${T('blacklistEmpty')}</p></div>`;return;}
  c.innerHTML=[...blacklist].map(u=>`<div class="user-item"><div class="avatar" style="background:${avatarColor(u)}">${u[0].toUpperCase()}</div><div class="user-info"><div class="username">@${u}</div></div><button class="btn-block blocked" onclick="toggleBlacklist('${u}')">${T('blacklistRemove')}</button></div>`).join('');
}

function closeBlacklist(e){if(!e||e.target===document.getElementById('blacklistModal'))document.getElementById('blacklistModal').classList.remove('open');}

// ══════════════════════════════════════════════════════
// TABS
// ══════════════════════════════════════════════════════
document.getElementById('tabsContainer').addEventListener('click',e=>{const t=e.target.closest('.tab');if(t)activateTab(t.dataset.tab);});

function activateTab(tab){
  currentTab=tab;
  document.querySelectorAll('.tab').forEach(t=>t.classList.toggle('active',t.dataset.tab===tab));
  currentList=tab==='blacklist'?[...blacklist]:(state[tab]||[]);
  const tabKey='tab'+tab.charAt(0).toUpperCase()+tab.slice(1);
  document.getElementById('listTitle').textContent=T(tabKey).replace(/^[^\s]+\s/,'');
  document.getElementById('listCount').textContent=currentList.length;
  document.getElementById('precisionNote').classList.toggle('show',tab==='notFollowing');
  document.getElementById('searchBar').value='';
  sortAZ=false;document.getElementById('sortBtn').classList.remove('active');document.getElementById('sortBtn').textContent='A→Z';
  renderList(currentList);
  saveSession();
}

// ══════════════════════════════════════════════════════
// SEARCH & SORT
// ══════════════════════════════════════════════════════
document.getElementById('searchBar').addEventListener('input',e=>{
  const q=e.target.value.toLowerCase().trim();
  let list=currentTab==='blacklist'?[...blacklist]:(state[currentTab]||[]);
  if(q)list=list.filter(u=>u.toLowerCase().includes(q));
  if(sortAZ)list=[...list].sort((a,b)=>a.localeCompare(b));
  renderList(list);
});

function toggleSort(){
  sortAZ=!sortAZ;
  document.getElementById('sortBtn').textContent=sortAZ?'Z→A':'A→Z';
  document.getElementById('sortBtn').classList.toggle('active',sortAZ);
  const q=document.getElementById('searchBar').value.toLowerCase().trim();
  let list=currentTab==='blacklist'?[...blacklist]:(state[currentTab]||[]);
  if(q)list=list.filter(u=>u.toLowerCase().includes(q));
  list=sortAZ?[...list].sort((a,b)=>a.localeCompare(b)):[...list].sort((a,b)=>b.localeCompare(a));
  renderList(list);
}

// ══════════════════════════════════════════════════════
// RENDER
// ══════════════════════════════════════════════════════
function avatarColor(u){return AVATAR_COLORS[u.charCodeAt(0)%AVATAR_COLORS.length];}

function renderList(list){
  const container=document.getElementById('userList');
  if(!list.length){container.innerHTML=`<div class="empty"><span>🎉</span><p>${T('emptyList')}</p></div>`;return;}
  container.innerHTML=list.slice(0,200).map((u,i)=>{
    const isBlocked=blacklist.has(u);
    return `<div class="user-item" style="animation-delay:${Math.min(i*0.02,0.4)}s">
      <div class="avatar" style="background:${avatarColor(u)}">${u[0].toUpperCase()}</div>
      <div class="user-info"><div class="username">@${u}</div><div class="user-sub">instagram.com/${u}</div></div>
      <div class="user-actions">
        <a href="https://instagram.com/${u}" target="_blank" class="btn-ig">🔗</a>
        <button class="btn-block ${isBlocked?'blocked':''}" onclick="toggleBlacklist('${u}')">🚫</button>
      </div>
    </div>`;
  }).join('');
  if(list.length>200)container.innerHTML+=`<div class="empty"><p>${T('showingOf')} ${list.length}.</p></div>`;
}

// ══════════════════════════════════════════════════════
// EXPORT
// ══════════════════════════════════════════════════════
function exportList(format){
  const list=currentTab==='blacklist'?[...blacklist]:currentList;
  if(!list.length){showToast(T('toastEmpty'));return;}
  let content,filename,mime;
  const tabKey='tab'+currentTab.charAt(0).toUpperCase()+currentTab.slice(1);
  const tabName=T(tabKey).replace(/^[^\s]+\s/,'');
  if(format==='txt'){
    content=`IGTracker — ${tabName}\n${new Date().toLocaleDateString()}\nTotal: ${list.length}\n\n`+list.map(u=>`@${u}\nhttps://instagram.com/${u}`).join('\n\n');
    filename=`ig_${currentTab}_${Date.now()}.txt`;mime='text/plain';
  }else{
    content=`Usuario,URL\n`+list.map(u=>`${u},https://instagram.com/${u}`).join('\n');
    filename=`ig_${currentTab}_${Date.now()}.csv`;mime='text/csv';
  }
  const a=document.createElement('a');a.href=URL.createObjectURL(new Blob([content],{type:mime}));a.download=filename;a.click();
  showToast(T('toastExport')+' '+format.toUpperCase());
}

// ══════════════════════════════════════════════════════
// RESET
// ══════════════════════════════════════════════════════
function resetApp(){
  sessionStorage.removeItem('ig_session');
  document.getElementById('results').style.display='none';
  document.getElementById('uploadView').style.display='block';
  document.getElementById('fileInput').value='';
  state.rawFollowers=[];
  state.rawFollowing=[];
}

// ══════════════════════════════════════════════════════
// SESSION PERSISTENCE (Stable & Backwards-Compatible)
// ══════════════════════════════════════════════════════
function saveSession(){
  try{
    sessionStorage.setItem('ig_session',JSON.stringify({
      state:{
        rawFollowers:state.rawFollowers,
        rawFollowing:state.rawFollowing
      },
      analysisMode,currentTab
    }));
  }catch(e){}
}

function restoreSession(){
  try{
    const raw=sessionStorage.getItem('ig_session');
    if(!raw)return false;
    const s=JSON.parse(raw);
    if(!s||!s.state||(!s.state.rawFollowers && !s.state.followers))return false;
    
    state.rawFollowers = s.state.rawFollowers || s.state.followers || [];
    state.rawFollowing = s.state.rawFollowing || s.state.following || [];
    analysisMode=s.analysisMode||'all';
    
    document.getElementById('modeAll').classList.toggle('selected',analysisMode==='all');
    document.getElementById('modePeriod').classList.toggle('selected',analysisMode==='period');
    
    updateStats();updateRatio();renderBlacklistBadge();
    document.getElementById('results').style.display='block';
    document.getElementById('uploadView').style.display='none';
    activateTab(s.currentTab||'notFollowing');
    if(appHistory.length>=1)renderHistory();
    return true;
  }catch(e){return false;}
}

// ══════════════════════════════════════════════════════
// LOADING & CONTROLS
// ══════════════════════════════════════════════════════
function showLoading(show){
  document.getElementById('loading').style.display=show?'block':'none';
  if(show){
    document.getElementById('uploadView').style.display='none';
  }
}
function showError(msg){document.getElementById('uploadView').style.display='block';document.getElementById('loading').style.display='none';document.getElementById('errorBox').style.display='block';document.getElementById('errorMsg').textContent=msg;}
function hideError(){document.getElementById('errorBox').style.display='none';}
let toastTimer;
function showToast(msg){const t=document.getElementById('toast');t.textContent=msg;t.classList.add('show');clearTimeout(toastTimer);toastTimer=setTimeout(()=>t.classList.remove('show'),2500);}

// ══════════════════════════════════════════════════════
// INIT
// ══════════════════════════════════════════════════════
applyLang();
renderBlacklistBadge();
if(appHistory.length>=1)renderHistory();
restoreSession();
</script>

</body>
</html>