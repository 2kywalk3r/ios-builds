<!-- Código index.html completo listo para reproducir -->
<!DOCTYPE html>
<html lang="es" data-theme="dark">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<title>IG Tracker Pro</title>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<style>
:root[data-theme="dark"] {
  --bg:#0a0a0f; --card:#13131a; --card2:#1a1a24;
  --accent:#c8ff00; --accent2:#ff6b6b; --accent3:#6b8cff;
  --red:#e8354a; --red-bg:rgba(232,53,74,0.12); --red-border:rgba(232,53,74,0.3);
  --green:#22c55e; --green-bg:rgba(34,197,94,0.12); --green-border:rgba(34,197,94,0.3);
  --text:#f0f0f8; --muted:#6b6b8a; --border:#2a2a3a;
}
:root[data-theme="light"] {
  --bg:#f4f4f8; --card:#ffffff; --card2:#eeeef4;
  --accent:#5a9e00; --accent2:#e03c3c; --accent3:#3a5fd4;
  --red:#c41230; --red-bg:rgba(196,18,48,0.08); --red-border:rgba(196,18,48,0.25);
  --green:#16a34a; --green-bg:rgba(22,163,74,0.08); --green-border:rgba(22,163,74,0.25);
  --text:#0a0a14; --muted:#8888aa; --border:#dddde8;
}
*{margin:0;padding:0;box-sizing:border-box;-webkit-tap-highlight-color:transparent}
body{font-family:'DM Sans',sans-serif;background:var(--bg);color:var(--text);min-height:100vh;overflow-x:hidden;transition:background .3s,color .3s}
body.rtl{direction:rtl;text-align:right}
body.rtl .step{flex-direction:row-reverse}
body.rtl .header-right{flex-direction:row-reverse}
body.rtl .ratio-label{flex-direction:row-reverse}
body.rtl .section-header{flex-direction:row-reverse}
body.rtl .search-row{flex-direction:row-reverse}
body.rtl .user-actions{flex-direction:row-reverse}
body.rtl .mode-option{flex-direction:row-reverse}
body.rtl .privacy{flex-direction:row-reverse}
body.rtl .history-popover{left:auto;right:0}
/* LANG SELECTOR */
.lang-btn{background:var(--card2);border:1px solid var(--border);border-radius:20px;padding:4px 10px;font-size:12px;color:var(--text);cursor:pointer;font-weight:600;display:flex;align-items:center;gap:4px;position:relative}
.lang-dropdown{display:none;position:absolute;top:calc(100% + 6px);right:0;background:var(--card);border:1px solid var(--border);border-radius:12px;overflow:hidden;z-index:300;box-shadow:0 8px 24px rgba(0,0,0,.3);min-width:140px}
.lang-dropdown.open{display:block}
.lang-option{padding:10px 14px;font-size:13px;cursor:pointer;display:flex;align-items:center;gap:8px;transition:background .15s;white-space:nowrap}
.lang-option:hover,.lang-option.active{background:var(--card2)}
.lang-option.active{font-weight:700;color:var(--accent)}

/* HEADER */
.header{padding:16px 20px;display:flex;align-items:center;justify-content:space-between;background:var(--card);border-bottom:1px solid var(--border);position:sticky;top:0;z-index:200}
.logo{font-family:'Syne',sans-serif;font-weight:800;font-size:22px;letter-spacing:-.5px}
.logo span{color:var(--accent)}
.header-right{display:flex;gap:8px;align-items:center}
.theme-btn{background:var(--card2);border:1px solid var(--border);border-radius:50%;width:36px;height:36px;display:flex;align-items:center;justify-content:center;cursor:pointer;font-size:16px;transition:transform .2s}
.theme-btn:active{transform:scale(.9)}
.version{background:var(--card2);border:1px solid var(--border);border-radius:20px;padding:4px 10px;font-size:11px;color:var(--muted)}

/* UPLOAD */
.hero{padding:28px 20px 16px;text-align:center}
.hero h1{font-family:'Syne',sans-serif;font-size:28px;font-weight:800;line-height:1.1;letter-spacing:-1px;margin-bottom:8px}
.hero h1 em{font-style:normal;color:var(--accent)}
.hero p{color:var(--muted);font-size:14px;line-height:1.6}
.privacy{background:var(--card2);border:1px solid var(--border);border-radius:14px;padding:12px 16px;margin:0 20px 16px;display:flex;gap:10px;align-items:center}
.privacy p{font-size:12px;color:var(--muted);line-height:1.5}
.privacy p strong{color:var(--text)}
.steps{padding:0 20px 16px}
.steps-label{font-family:'Syne',sans-serif;font-size:11px;font-weight:700;color:var(--muted);letter-spacing:2px;text-transform:uppercase;margin-bottom:12px}
.step{display:flex;gap:12px;align-items:flex-start;margin-bottom:9px}
.step-n{width:24px;height:24px;border-radius:50%;background:var(--accent);color:#000;font-family:'Syne',sans-serif;font-weight:800;font-size:11px;display:flex;align-items:center;justify-content:center;flex-shrink:0;margin-top:2px}
.step-t{font-size:13px;color:var(--muted);line-height:1.6}
.step-t strong{color:var(--text)}
.upload-section{padding:0 20px 28px}
.upload-card{background:var(--card);border:2px dashed var(--border);border-radius:20px;padding:32px 20px;text-align:center;transition:all .3s}
.upload-card.drag-over{border-color:var(--accent);background:rgba(200,255,0,.04)}
.upload-icon{font-size:44px;display:block;margin-bottom:12px}
.upload-card h3{font-family:'Syne',sans-serif;font-size:16px;font-weight:700;margin-bottom:6px}
.upload-card p{font-size:13px;color:var(--muted);margin-bottom:20px;line-height:1.5}
.btn-upload{background:var(--accent);color:#000;border:none;border-radius:14px;padding:14px 32px;font-family:'Syne',sans-serif;font-weight:800;font-size:15px;cursor:pointer;display:inline-flex;align-items:center;gap:8px;transition:transform .15s,opacity .15s;-webkit-appearance:none}
.btn-upload:active{transform:scale(.96);opacity:.9}
#fileInput{display:none}
.error-box{display:none;background:rgba(255,107,107,.1);border:1px solid rgba(255,107,107,.3);border-radius:14px;padding:14px 16px;margin:0 20px 16px;font-size:13px;color:var(--accent2);line-height:1.6}

/* MODE SELECTOR */
.mode-selector{padding:0 20px 16px}
.mode-label{font-family:'Syne',sans-serif;font-size:11px;font-weight:700;color:var(--muted);letter-spacing:2px;text-transform:uppercase;margin-bottom:10px}
.mode-options{display:flex;flex-direction:column;gap:8px}
.mode-option{background:var(--card);border:2px solid var(--border);border-radius:14px;padding:14px 16px;cursor:pointer;transition:all .2s;display:flex;align-items:flex-start;gap:12px}
.mode-option.selected{border-color:var(--accent);background:rgba(200,255,0,.06)}
.mode-radio{width:18px;height:18px;border-radius:50%;border:2px solid var(--border);flex-shrink:0;margin-top:2px;transition:all .2s;display:flex;align-items:center;justify-content:center}
.mode-option.selected .mode-radio{border-color:var(--accent);background:var(--accent)}
.mode-radio::after{content:'';width:7px;height:7px;border-radius:50%;background:#000;display:none}
.mode-option.selected .mode-radio::after{display:block}
.mode-text h4{font-family:'Syne',sans-serif;font-size:14px;font-weight:700;margin-bottom:3px}
.mode-text p{font-size:12px;color:var(--muted);line-height:1.5}

/* LOADING */
.loading{display:none;text-align:center;padding:60px 20px}
.spinner{width:44px;height:44px;border:3px solid var(--border);border-top-color:var(--accent);border-radius:50%;animation:spin .8s linear infinite;margin:0 auto 16px}
@keyframes spin{to{transform:rotate(360deg)}}
.loading p{color:var(--muted);font-size:14px}

/* RESULTS */
.results{display:none;padding:0 20px 60px}

/* STATS GRID */
.stats-grid{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:16px}
.stat-card{background:var(--card);border:1px solid var(--border);border-radius:16px;padding:16px;text-align:center;position:relative;overflow:hidden}

/* "No te siguen" card — deep red */
.stat-card.danger{background:var(--red-bg);border-color:var(--red-border)}
.stat-card.danger .stat-num{color:var(--red)}
.stat-card.danger .stat-label{color:var(--red);opacity:.8}
.stat-card.danger .stat-arrow{color:var(--red)}

/* "Seguidores" card — green */
.stat-card.positive{background:var(--green-bg);border-color:var(--green-border)}
.stat-card.positive .stat-num{color:var(--green)}
.stat-card.positive .stat-label{color:var(--green);opacity:.8}
.stat-card.positive .stat-arrow{color:var(--green)}

.stat-num{font-family:'Syne',sans-serif;font-size:30px;font-weight:800;line-height:1;margin-bottom:2px;display:flex;align-items:center;justify-content:center;gap:4px}
.stat-arrow{font-size:20px;font-weight:900;line-height:1}
.stat-label{font-size:11px;color:var(--muted);text-transform:uppercase;letter-spacing:.5px}

/* RATIO */
.ratio-bar-wrap{background:var(--card);border:1px solid var(--border);border-radius:14px;padding:14px 16px;margin-bottom:16px}
.ratio-bar-wrap.locked{opacity:.5;pointer-events:none;position:relative}
.ratio-locked-msg{font-size:11px;color:var(--muted);margin-top:8px;text-align:center;font-style:italic}
.ratio-label{font-size:12px;color:var(--muted);margin-bottom:8px;display:flex;justify-content:space-between}
.ratio-label span{font-weight:600;color:var(--text)}
.ratio-track{background:var(--border);border-radius:8px;height:10px;overflow:hidden}
.ratio-fill{height:100%;background:var(--accent);border-radius:8px;transition:width 1s cubic-bezier(.4,0,.2,1)}

/* HISTORY */
.history-strip{display:flex;gap:8px;overflow-x:auto;padding-bottom:4px;scrollbar-width:none}
.history-strip::-webkit-scrollbar{display:none}
.history-chip{flex-shrink:0;background:var(--card);border:1px solid var(--border);border-radius:10px;padding:8px 12px;font-size:11px;color:var(--muted);cursor:pointer;transition:border-color .2s;position:relative}
.history-chip:active{border-color:var(--accent)}
.history-chip .hdate{font-weight:700;color:var(--text);display:block;margin-bottom:2px;font-size:12px}
.history-chip .hdiff{font-size:11px}
.history-chip .hdiff.lost{color:var(--red)}
.history-chip .hdiff.gained{color:var(--green)}
.history-chip .hdiff.neutral{color:var(--muted)}

/* HISTORY POPOVER */
.history-popover{display:none;position:absolute;top:calc(100% + 8px);left:0;z-index:150;background:var(--card);border:1px solid var(--border);border-radius:14px;padding:14px 16px;min-width:220px;box-shadow:0 8px 32px rgba(0,0,0,.35);animation:fadeUp .18s ease}
.history-popover.open{display:block}
.history-popover h5{font-family:'Syne',sans-serif;font-size:13px;font-weight:800;margin-bottom:10px;color:var(--text)}
.popover-row{display:flex;justify-content:space-between;align-items:center;padding:5px 0;border-bottom:1px solid var(--border);font-size:12px}
.popover-row:last-child{border-bottom:none}
.popover-row span:first-child{color:var(--muted)}
.popover-row span:last-child{font-weight:700;color:var(--text)}
.popover-row span.red{color:var(--red)}
.popover-row span.green{color:var(--green)}

/* BLACKLIST */
.blacklist-count{display:inline-flex;align-items:center;gap:6px;background:rgba(255,107,107,.1);border:1px solid rgba(255,107,107,.2);border-radius:8px;padding:4px 10px;font-size:12px;color:var(--accent2);margin-bottom:16px;cursor:pointer}

/* SEARCH + SORT */
.search-row{display:flex;gap:8px;margin-bottom:12px}
.search-bar{background:var(--card);border:1px solid var(--border);border-radius:12px;padding:12px 16px;font-family:'DM Sans',sans-serif;font-size:14px;color:var(--text);flex:1;outline:none;-webkit-appearance:none;transition:border-color .2s}
.search-bar:focus{border-color:var(--accent)}
.search-bar::placeholder{color:var(--muted)}
.sort-btn{background:var(--card);border:1px solid var(--border);border-radius:12px;padding:12px 14px;font-size:13px;color:var(--muted);cursor:pointer;white-space:nowrap;transition:all .2s;flex-shrink:0}
.sort-btn.active{border-color:var(--accent);color:var(--accent)}

/* TABS */
.tabs{display:flex;gap:8px;margin-bottom:16px;overflow-x:auto;padding-bottom:4px;scrollbar-width:none}
.tabs::-webkit-scrollbar{display:none}
.tab{flex-shrink:0;background:var(--card);border:1px solid var(--border);border-radius:20px;padding:9px 15px;font-size:13px;font-weight:500;color:var(--muted);cursor:pointer;transition:all .2s;white-space:nowrap}
.tab.active{background:var(--accent);border-color:var(--accent);color:#000;font-weight:700}

/* LIST */
.section-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:12px}
.section-title{font-family:'Syne',sans-serif;font-size:17px;font-weight:800}
.count-pill{background:var(--card2);border:1px solid var(--border);border-radius:8px;padding:3px 10px;font-size:12px;color:var(--muted);font-weight:600}

/* PRECISION NOTE */
.precision-note{display:none;background:rgba(107,140,255,.10);border:1px solid rgba(107,140,255,.25);border-radius:14px;padding:14px 16px;margin-bottom:14px;font-size:13px;line-height:1.55;color:var(--text)}
.precision-note strong{font-weight:700;color:var(--text)}
.precision-note.show{display:block}
.user-list{display:flex;flex-direction:column;gap:8px}
.user-item{background:var(--card);border:1px solid var(--border);border-radius:14px;padding:12px 14px;display:flex;align-items:center;gap:12px;animation:fadeUp .22s ease both}
@keyframes fadeUp{from{opacity:0;transform:translateY(6px)}to{opacity:1;transform:translateY(0)}}
.avatar{width:42px;height:42px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-family:'Syne',sans-serif;font-weight:800;font-size:16px;color:#fff;flex-shrink:0}
.user-info{flex:1;min-width:0}
.username{font-weight:600;font-size:14px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.user-sub{font-size:11px;color:var(--muted);margin-top:2px}
.user-actions{display:flex;gap:6px;align-items:center;flex-shrink:0}
.btn-ig{background:transparent;border:1px solid var(--border);border-radius:8px;padding:5px 8px;font-size:13px;cursor:pointer;transition:all .2s;color:var(--muted);text-decoration:none;display:inline-flex;align-items:center}
.btn-ig:active{border-color:var(--accent3);color:var(--accent3)}
.btn-block{background:transparent;border:1px solid var(--border);border-radius:8px;padding:5px 8px;font-size:12px;cursor:pointer;transition:all .2s;color:var(--muted)}
.btn-block.blocked{background:rgba(255,107,107,.12);border-color:var(--accent2);color:var(--accent2)}
.empty{text-align:center;padding:36px 20px;color:var(--muted)}
.empty span{font-size:36px;display:block;margin-bottom:10px}
.empty p{font-size:14px}

/* ACTIONS */
.export-row{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-top:20px}
.btn-export{border-radius:13px;padding:13px 12px;font-family:'Syne',sans-serif;font-weight:700;font-size:13px;cursor:pointer;display:flex;align-items:center;justify-content:center;gap:6px;transition:transform .15s;-webkit-appearance:none;border:1px solid var(--border);background:var(--card2);color:var(--text)}
.btn-export:active{transform:scale(.97)}
.btn-action{border-radius:13px;padding:14px 20px;font-family:'Syne',sans-serif;font-weight:700;font-size:14px;cursor:pointer;width:100%;display:flex;align-items:center;justify-content:center;gap:8px;transition:transform .15s,opacity .15s;-webkit-appearance:none;border:none}
.btn-action:active{transform:scale(.98);opacity:.85}
.btn-secondary{background:var(--card2);border:1px solid var(--border)!important;color:var(--text)}
.btn-danger{background:rgba(255,107,107,.12);border:1px solid rgba(255,107,107,.3)!important;color:var(--accent2)}

/* MODAL */
.modal-overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,.7);z-index:300;align-items:flex-end;justify-content:center}
.modal-overlay.open{display:flex}
.modal{background:var(--card);border-radius:24px 24px 0 0;padding:24px 20px 40px;width:100%;max-width:500px;animation:slideUp .3s ease;max-height:80vh;overflow-y:auto}
@keyframes slideUp{from{transform:translateY(100%)}to{transform:translateY(0)}}
.modal-handle{width:40px;height:4px;background:var(--border);border-radius:2px;margin:0 auto 20px}
.modal h3{font-family:'Syne',sans-serif;font-size:18px;font-weight:800;margin-bottom:16px}
.modal-close{float:right;background:var(--card2);border:none;border-radius:50%;width:30px;height:30px;font-size:16px;cursor:pointer;color:var(--muted)}

/* TOAST */
.toast{position:fixed;bottom:24px;left:50%;transform:translateX(-50%) translateY(80px);background:var(--text);color:var(--bg);border-radius:12px;padding:10px 20px;font-size:13px;font-weight:600;z-index:400;transition:transform .3s ease;white-space:nowrap;max-width:90vw;text-align:center}
.toast.show{transform:translateX(-50%) translateY(0)}

/* RATIO POPUP */
.ratio-bar-wrap{cursor:pointer;transition:opacity .15s}
.ratio-bar-wrap:active{opacity:.8}
/* full-screen overlay for popups */
.popup-overlay{display:none;position:fixed;inset:0;z-index:250;background:transparent}
.popup-overlay.open{display:block}
/* ratio popup card */
.ratio-popup{display:none;position:fixed;bottom:0;left:0;right:0;z-index:260;background:var(--card);border-radius:24px 24px 0 0;padding:10px 18px 24px;box-shadow:0 -8px 40px rgba(0,0,0,.4);animation:slideUp .28s cubic-bezier(.4,0,.2,1);max-height:72vh;overflow-y:auto;touch-action:pan-y;will-change:transform;transition:transform .25s cubic-bezier(.4,0,.2,1)}
.ratio-popup.open{display:block}
.ratio-popup.dragging{transition:none!important;animation:none!important}
.ratio-popup-grab{padding:8px 0 6px;margin:0 -18px 6px;cursor:grab;touch-action:none;-webkit-user-select:none;user-select:none}
.ratio-popup-grab:active{cursor:grabbing}
.ratio-popup-handle{width:44px;height:5px;background:var(--border);border-radius:3px;margin:0 auto;pointer-events:none}
.ratio-popup-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:8px}
.ratio-popup-header h3{font-family:'Syne',sans-serif;font-size:17px;font-weight:800}
.ratio-popup-close{background:var(--card2);border:none;border-radius:50%;width:30px;height:30px;font-size:15px;cursor:pointer;color:var(--muted);display:flex;align-items:center;justify-content:center}
.ratio-popup-value{font-family:'Syne',sans-serif;font-size:40px;font-weight:800;text-align:center;margin:2px 0 2px;line-height:1}
.ratio-popup-sublabel{text-align:center;font-size:12px;color:var(--muted);margin-bottom:12px}
.ratio-track-big{background:var(--border);border-radius:10px;height:12px;overflow:hidden;margin-bottom:14px}
.ratio-fill-big{height:100%;background:var(--accent);border-radius:10px;transition:width 1s cubic-bezier(.4,0,.2,1)}
.ratio-explain-block{background:var(--card2);border-radius:12px;padding:10px 14px;margin-bottom:8px}
.ratio-explain-block p{font-size:12.5px;color:var(--muted);line-height:1.55}
.ratio-explain-block strong{color:var(--text)}
.ratio-formula{background:var(--bg);border:1px solid var(--border);border-radius:10px;padding:8px 14px;font-family:'Syne',sans-serif;font-weight:700;font-size:12.5px;text-align:center;margin-bottom:10px;color:var(--text)}
.ratio-scale{display:grid;grid-template-columns:1fr 1fr 1fr;gap:6px;margin-bottom:6px}
.ratio-scale-item{background:var(--card2);border-radius:10px;padding:8px 6px;text-align:center}
.ratio-scale-item .rs-val{font-family:'Syne',sans-serif;font-weight:800;font-size:14px;margin-bottom:2px}
.ratio-scale-item .rs-label{font-size:10px;color:var(--muted);line-height:1.4}
.ratio-locked-note{background:rgba(107,140,255,.1);border:1px solid rgba(107,140,255,.25);border-radius:10px;padding:8px 14px;font-size:11.5px;color:var(--accent3);margin-top:4px;line-height:1.5}

/* STAT CARDS — clickable hint */
.stat-card{cursor:pointer;transition:transform .12s,box-shadow .12s}
.stat-card:active{transform:scale(.97)}

/* HISTORY COMPARISON POPUP */
.hist-popup{display:none;position:fixed;bottom:0;left:0;right:0;z-index:260;background:var(--card);border-radius:24px 24px 0 0;padding:24px 20px 40px;box-shadow:0 -8px 40px rgba(0,0,0,.4);animation:slideUp .28s cubic-bezier(.4,0,.2,1);max-height:85vh;overflow-y:auto}
.hist-popup.open{display:block}
.hist-popup-handle{width:40px;height:4px;background:var(--border);border-radius:2px;margin:0 auto 20px}
.hist-popup-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:16px}
.hist-popup-header h3{font-family:'Syne',sans-serif;font-size:17px;font-weight:800}
.hist-popup-close{background:var(--card2);border:none;border-radius:50%;width:32px;height:32px;font-size:16px;cursor:pointer;color:var(--muted)}
.hist-compare-row{display:flex;align-items:center;gap:10px;margin-bottom:10px}
.hist-compare-label{font-size:12px;color:var(--muted);width:90px;flex-shrink:0;text-align:right}
.hist-compare-bar-wrap{flex:1;background:var(--border);border-radius:6px;height:10px;overflow:hidden}
.hist-compare-bar{height:100%;border-radius:6px;transition:width .8s cubic-bezier(.4,0,.2,1)}
.hist-compare-val{font-family:'Syne',sans-serif;font-weight:700;font-size:13px;width:36px;text-align:left;flex-shrink:0}
.hist-delta-row{display:flex;justify-content:space-between;padding:8px 0;border-bottom:1px solid var(--border);font-size:13px}
.hist-delta-row:last-child{border-bottom:none}
.hist-delta-row span:first-child{color:var(--muted)}
.hist-delta-pos{color:var(--green);font-weight:700}
.hist-delta-neg{color:var(--red);font-weight:700}
.hist-delta-neu{color:var(--muted);font-weight:700}
.hist-chip-active{border-color:var(--accent)!important}
@keyframes slideUp{from{transform:translateY(100%)}to{transform:translateY(0)}}
</style>
</head>
<body>

<div class="header">
  <div class="logo">IG<span>Tracker</span></div>
  <div class="header-right">
    <div class="lang-btn" id="langBtn" onclick="toggleLangDropdown(event)">
      <span id="langFlag">🇪🇸</span><span id="langCode">ES</span>
      <div class="lang-dropdown" id="langDropdown">
        <div class="lang-option active" data-lang="es" onclick="setLang('es',event)">🇪🇸 Español</div>
        <div class="lang-option" data-lang="en-US" onclick="setLang('en-US',event)">🇺🇸 English (US)</div>
        <div class="lang-option" data-lang="en-GB" onclick="setLang('en-GB',event)">🇬🇧 English (UK)</div>
        <div class="lang-option" data-lang="pt" onclick="setLang('pt',event)">🇧🇷 Português</div>
        <div class="lang-option" data-lang="fr" onclick="setLang('fr',event)">🇫🇷 Français</div>
        <div class="lang-option" data-lang="de" onclick="setLang('de',event)">🇩🇪 Deutsch</div>
        <div class="lang-option" data-lang="ja" onclick="setLang('ja',event)">🇯🇵 日本語</div>
        <div class="lang-option" data-lang="hi" onclick="setLang('hi',event)">🇮🇳 हिन्दी</div>
        <div class="lang-option" data-lang="ar" onclick="setLang('ar',event)">🇸🇦 العربية</div>
        <div class="lang-option" data-lang="id" onclick="setLang('id',event)">🇮🇩 Indonesia</div>
        <div class="lang-option" data-lang="ru" onclick="setLang('ru',event)">🇷🇺 Русский</div>
      </div>
    </div>
    <div class="theme-btn" id="themeBtn">🌙</div>
    <div class="version">v21</div>
  </div>
</div>

<!-- UPLOAD VIEW -->
<div id="uploadView">
  <div class="hero">
    <h1 id="heroTitle">Descubre quién <em>no te</em> sigue de vuelta</h1>
    <p id="heroSub">Analiza tus datos de Instagram. Local, privado, sin servidores.</p>
  </div>
  <div class="privacy">
    <span style="font-size:20px;flex-shrink:0">🔒</span>
    <p><strong id="privacyStrong">100% privado.</strong> <span id="privacySub">Tus archivos nunca salen de tu dispositivo. Sin login.</span></p>
  </div>
  <div class="steps">
    <div class="steps-label" id="stepsLabel">Cómo obtener tus datos</div>
    <div class="step"><div class="step-n">1</div><div class="step-t" id="step1">Instagram → <strong>Perfil → ☰ → Configuración → Actividad → Descargar tu información</strong></div></div>
    <div class="step"><div class="step-n">2</div><div class="step-t" id="step2">Selecciona formato <strong>JSON</strong> y solicita la descarga. Recibirás un ZIP por email.</div></div>
    <div class="step"><div class="step-n">3</div><div class="step-t" id="step3">Descomprime el ZIP → carpeta <strong>connections/followers_and_following/</strong></div></div>
    <div class="step"><div class="step-n">4</div><div class="step-t" id="step4">Selecciona <strong>followers_1.json</strong> y <strong>following.json</strong> a la vez.</div></div>
  </div>

  <div class="error-box" id="errorBox">⚠️ <span id="errorMsg"></span></div>

  <div class="mode-selector">
    <div class="mode-label" id="modeLabel">¿Qué período elegiste en Instagram?</div>
    <div class="mode-options">
      <div class="mode-option selected" id="modeAll" onclick="selectMode('all')">
        <div class="mode-radio"></div>
        <div class="mode-text">
          <h4 id="modeAllTitle">🌐 Cualquier fecha / Todo el historial</h4>
          <p id="modeAllDesc">Muestra quién de todos a quien sigues no te sigue de vuelta. También actualiza el ratio real.</p>
        </div>
      </div>
      <div class="mode-option" id="modePeriod" onclick="selectMode('period')">
        <div class="mode-radio"></div>
        <div class="mode-text">
          <h4 id="modePeriodTitle">📅 Período concreto (semana, mes, año…)</h4>
          <p id="modePeriodDesc">Muestra de los que te siguieron en ese período cuántos sigues tú, quiénes son nuevos y quiénes te dejaron de seguir.</p>
        </div>
      </div>
    </div>
  </div>

  <div class="upload-section">
    <div class="upload-card" id="uploadCard">
      <span class="upload-icon">📂</span>
      <h3 id="uploadTitle">Sube tus archivos JSON</h3>
      <p id="uploadDesc">Selecciona <strong>followers_1.json</strong> y <strong>following.json</strong> al mismo tiempo</p>
      <button class="btn-upload" id="uploadBtn">📤 Seleccionar archivos</button>
      <input type="file" id="fileInput" multiple accept=".json">
    </div>
  </div>
</div>

<!-- LOADING -->
<div class="loading" id="loading">
  <div class="spinner"></div>
  <p id="analyzingText">Analizando tus datos...</p>
</div>

<!-- RESULTS -->
<div class="results" id="results">

  <!-- STATS: "No te siguen" (rojo) + "Seguidores" (verde) -->
  <div class="stats-grid" style="margin-top:16px">
    <div class="stat-card danger" onclick="activateTab('notFollowing')">
      <div class="stat-num"><span id="statNotFollow">0</span><span class="stat-arrow">↓</span></div>
      <div class="stat-label" id="labelNotFollow">No te siguen</div>
    </div>
    <div class="stat-card positive" onclick="activateTab('followers')">
      <div class="stat-num"><span id="statFollowers">0</span><span class="stat-arrow">+</span></div>
      <div class="stat-label" id="labelFollowers">Seguidores</div>
    </div>
    <div class="stat-card" onclick="activateTab('following')">
      <div class="stat-num" id="statFollowing">0</div>
      <div class="stat-label" id="labelFollowing">Siguiendo</div>
    </div>
    <div class="stat-card" onclick="activateTab('mutual')">
      <div class="stat-num" id="statMutual">0</div>
      <div class="stat-label" id="labelMutual">Mutuos</div>
    </div>
  </div>

  <!-- RATIO — solo visible en modo 'all' -->
  <div class="ratio-bar-wrap" id="ratioWrap" onclick="openRatioPopup(event)">
    <div class="ratio-label"><span id="ratioLabel">Ratio seguidores/siguiendo</span><span id="ratioText">—</span></div>
    <div class="ratio-track"><div class="ratio-fill" id="ratioFill" style="width:0%"></div></div>
  </div>
  <div class="ratio-bar-wrap locked" id="ratioLocked" style="display:none" onclick="openRatioPopup(event)">
    <div class="ratio-label"><span id="ratioLabelLocked">Ratio seguidores/siguiendo</span><span id="ratioSaved">—</span></div>
    <div class="ratio-track"><div class="ratio-fill" id="ratioFillSaved" style="width:0%"></div></div>
    <div class="ratio-locked-msg" id="ratioLockedMsg">🔒 Ratio del último historial completo · Solo se actualiza con "Cualquier fecha"</div>
  </div>

  <!-- HISTORY -->
  <div id="historySection" style="display:none;margin-bottom:16px">
    <div id="historyLabel" style="font-family:'Syne',sans-serif;font-size:11px;font-weight:700;color:var(--muted);letter-spacing:2px;text-transform:uppercase;margin-bottom:10px">📊 Historial de análisis</div>
    <div class="history-strip" id="historyStrip"></div>
  </div>

  <!-- SEARCH + SORT -->
  <div class="search-row">
    <input type="text" class="search-bar" id="searchBar" placeholder="🔍 Buscar usuario...">
    <button class="sort-btn" id="sortBtn" onclick="toggleSort()">A→Z</button>
  </div>

  <!-- TABS -->
  <div class="tabs" id="tabsContainer">
    <div class="tab active" data-tab="notFollowing" id="tabNotFollowing">❌ No te siguen</div>
    <div class="tab" data-tab="mutual" id="tabMutual">✅ Mutuos</div>
    <div class="tab" data-tab="followers" id="tabFollowers">👥 Seguidores</div>
    <div class="tab" data-tab="following" id="tabFollowing">➡️ Siguiendo</div>
    <div class="tab" data-tab="blacklist" id="tabBlacklist">🚫 Lista negra</div>
  </div>

  <div class="section-header">
    <div class="section-title" id="listTitle">No te siguen</div>
    <div class="count-pill" id="listCount">0</div>
  </div>
  <div class="precision-note" id="precisionNote"></div>
  <div class="user-list" id="userList"></div>

  <div class="export-row">
    <button class="btn-export" id="exportTxtBtn" onclick="exportList('txt')">📋 Exportar TXT</button>
    <button class="btn-export" id="exportCsvBtn" onclick="exportList('csv')">📊 Exportar CSV</button>
  </div>
  <div style="margin-top:10px;display:flex;flex-direction:column;gap:8px">
    <button class="btn-action btn-secondary" id="resetBtn" onclick="resetApp()">🔄 Analizar otros archivos</button>
    <button class="btn-action btn-danger" id="clearHistBtn" onclick="clearHistory()">🗑 Borrar historial guardado</button>
  </div>
</div>

<!-- BLACKLIST MODAL -->
<div class="modal-overlay" id="blacklistModal" onclick="closeBlacklist(event)">
  <div class="modal">
    <div class="modal-handle"></div>
    <button class="modal-close" onclick="closeBlacklist()">✕</button>
    <h3 id="blacklistModalTitle">🚫 Lista negra</h3>
    <p id="blacklistModalDesc" style="font-size:13px;color:var(--muted);margin-bottom:16px">Estos usuarios se ignoran en el análisis.</p>
    <div id="blacklistContent" style="display:flex;flex-direction:column;gap:8px;max-height:50vh;overflow-y:auto"></div>
  </div>
</div>

<!-- POPUP OVERLAY (closes any open popup on tap) -->
<div class="popup-overlay" id="popupOverlay" onclick="closeAllPopups()"></div>

<!-- RATIO POPUP -->
<div class="ratio-popup" id="ratioPopup">
  <div class="ratio-popup-grab" id="ratioPopupGrab"><div class="ratio-popup-handle"></div></div>
  <div class="ratio-popup-header">
    <h3 id="rp_title">📊 Ratio</h3>
    <button class="ratio-popup-close" onclick="closeAllPopups()">✕</button>
  </div>
  <div class="ratio-popup-value" id="rp_value">—</div>
  <div class="ratio-popup-sublabel" id="rp_sublabel"></div>
  <div class="ratio-track-big"><div class="ratio-fill-big" id="rp_fill" style="width:0%"></div></div>
  <div class="ratio-explain-block">
    <p id="rp_explain1"></p>
  </div>
  <div class="ratio-explain-block" style="margin-bottom:12px">
    <p id="rp_explain2"></p>
  </div>
  <div class="ratio-formula" id="rp_formula"></div>
  <div class="ratio-scale" id="rp_scale"></div>
  <div class="ratio-locked-note" id="rp_locked" style="display:none"></div>
</div>

<!-- HISTORY COMPARISON POPUP -->
<div class="hist-popup" id="histPopup">
  <div class="hist-popup-handle"></div>
  <div class="hist-popup-header">
    <h3 id="hp_title">📊 Comparativa</h3>
    <button class="hist-popup-close" onclick="closeAllPopups()">✕</button>
  </div>
  <div id="hp_body"></div>
</div>

<!-- TOAST -->
<div class="toast" id="toast"></div>

<script>
// ══════════════════════════════════════════════════════
// TRANSLATIONS
// ══════════════════════════════════════════════════════
